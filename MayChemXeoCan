    btn.Parent = TabBar
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, -40)
    frame.Position = UDim2.new(0, 0, 0, 40)
    frame.BackgroundTransparency = 1
    frame.Visible = isActive
    frame.Parent = Menu
    
