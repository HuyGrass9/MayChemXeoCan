local CheckoutLoop = nil
function StartCheckout()
    if CheckoutLoop then return end
    if not OperatePaymentRE or not PaymentFinishRE then
        Logger:Add("LOI: Khong tim thay Payment Remote")
        return
    end
    local cashierDesk = workspace:FindFirstChild("Resources") and workspace.Resources:FindFirstChild("Building") and workspace.Resources.Building:FindFirstChild("CashierDesk")
    if not cashierDesk then
        Logger:Add("LOI: Khong tim thay CashierDesk")
        return
    end
    CheckoutLoop = t_spawn(function()
        while Config.CheckoutEnabled do
            local customerNearby = false
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("Head") then
                    local hrp = obj:FindFirstChild("HumanoidRootPart")
                    if hrp and (hrp.Position - cashierDesk.Position).Magnitude < 15 then
                        customerNearby = true
                        break
                    end
                end
            end
            if customerNearby then
                pcall(function() OperatePaymentRE:FireServer(cashierDesk, 1, "PutCash") end)
                t_wait(0.1)
                pcall(function() OperatePaymentRE:FireServer(cashierDesk, 0.5, "PutCash") end)
                t_wait(0.1)
                pcall(function() PaymentFinishRE:FireServer("PaidFinish", 1) end)
                t_wait(0.15)
                pcall(function() OperatePaymentRE:FireServer(cashierDesk, 0.5, "TakeCash") end)
                t_wait(0.1)
                pcall(function() OperatePaymentRE:FireServer(cashierDesk, -1, "ClearAllCash") end)
                Logger:Add("Da tinh tien khach")
                t_wait(Config.CheckoutDelay)
            end
            t_wait(0.3)
        end
    end)
end
function StopCheckout()
    if CheckoutLoop then task.cancel(CheckoutLoop); CheckoutLoop = nil end
end

Tab1:CreateToggle("Auto Checkout", "CheckoutEnabled", function(v)
    Logger:Add("Auto Checkout: " .. (v and "ON" or "OFF"))
    if v then StartCheckout() else StopCheckout() end
end)
