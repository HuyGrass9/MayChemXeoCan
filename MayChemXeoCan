task.spawn(function()
    while true do
        if getgenv().AutoEggUltra and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
            local tool = LP.Backpack:FindFirstChild("Portal-Portal") or LP.Character:FindFirstChild("Portal-Portal")
            if tool then
                for _, idx in ipairs(TargetIndices) do
                    if not getgenv().AutoEggUltra then break end
                    
                    if tool.Parent ~= LP.Character then
                        LP.Character.Humanoid:EquipTool(tool)
                        task.wait(0.5)
                    end
                    
                    VIM:SendKeyEvent(true, Enum.KeyCode.C, false, game)
                    task.wait(0.2)
                    VIM:SendKeyEvent(false, Enum.KeyCode.C, false, game)
                    
                    task.wait(1.5)
                    local buttons = GetPortalButtons()
                    if buttons and buttons[idx] then
                        ForceClickButton(buttons[idx])
                        task.wait(2.5)
                        
                        if LP.Character and LP.Character:FindFirstChild("Humanoid") then
                            LP.Character.Humanoid:UnequipTools()
                        end
                        
                        SmoothMoveAway()
                        
                        local t = 0
                        while t < 6 and getgenv().AutoEggUltra do
                            SnipeAllEggs()
                            task.wait(1)
                            t = t + 1
                        end
                    else
                        VIM:SendKeyEvent(true, Enum.KeyCode.C, false, game)
                        task.wait(0.2)
                        VIM:SendKeyEvent(false, Enum.KeyCode.C, false, game)
                        task.wait(1)
                    end
                end
            end
        end
        task.wait(1)
    end
end)
