local function SafeGetPlayerInfo(plr)
    local lvl, race, hp, mhp, weap = "?", "?", 0, 0, "None"
    pcall(function()
        if plr:FindFirstChild("Data") then
            if plr.Data:FindFirstChild("Level") then lvl = tostring(plr.Data.Level.Value) end
            if plr.Data:FindFirstChild("Race") then race = tostring(plr.Data.Race.Value) end
        end
        if plr.Character then
            local hum = plr.Character:FindFirstChild("Humanoid")
            if hum then hp = math.floor(hum.Health); mhp = math.floor(hum.MaxHealth) end
            local tool = plr.Character:FindFirstChildOfClass("Tool")
            if tool then weap = tool.Name end
        end
    end)
    return lvl, race, hp, mhp, weap
end

