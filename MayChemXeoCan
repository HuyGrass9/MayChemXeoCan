local Logger = { entries = {}, maxEntries = 200 }
function Logger:Add(msg)
    local entry = "[" .. os.date("%H:%M:%S") .. "] " .. msg
    table.insert(self.entries, entry)
    if #self.entries > self.maxEntries then table.remove(self.entries, 1) end
    if _G.StatusLog then _G.StatusLog.Text = table.concat(self.entries, "\n") end
end
function Logger:Clear() self.entries = {}; if _G.StatusLog then _G.StatusLog.Text = "" end end

