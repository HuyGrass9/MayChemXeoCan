local function MayChemXeoCan_ApexPvP(char)
    char.ChildAdded:Connect(function(v)
        if v:IsA("Tool") and string.find(string.lower(v.Name), "katana") then UI.Enabled = true end
        if v:IsA("BoolValue") or v:IsA("StringValue") then
            local name = string.lower(v.Name)
            if string.find(name, "busy") or string.find(name, "cant") or string.find(name, "nodash") or string.find(name, "nojump") then
                task.spawn(function()
                    local mDelay = tonumber(Config.MacroDelay) or 0.04
                    task.wait(mDelay)
                    while char and char.Parent and MayChemXeoCan_IsHolding(char) do RunService.Heartbeat:Wait() end
                    if v and v.Parent and v:IsA("BoolValue") then v.Value = false end
                end)
            end
        end
    end)
end

if LP.Character then MayChemXeoCan_ApexPvP(LP.Character) end
LP.CharacterAdded:Connect(MayChemXeoCan_ApexPvP)

RunService.RenderStepped:Connect(function()
    if LP.Character then
        local hum = LP.Character:FindFirstChild("Humanoid")
        if hum and hum.WalkSpeed < 35 then
            local isStunned = false
            for _, tag in pairs(LP.Character:GetChildren()) do
                if tag:IsA("BoolValue") and string.find(string.lower(tag.Name), "stun") and tag.Value == true then isStunned = true; break end
            end
            if not isStunned and not MayChemXeoCan_IsHolding(LP.Character) then hum.WalkSpeed = 35 end
        end
    end
end)

