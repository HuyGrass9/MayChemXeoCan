local function MayChemXeoCan_ApexPvP(char)
    char.DescendantAdded:Connect(function(v)
        if v:IsA("Tool") and string.find(string.lower(v.Name), "katana") then UI.Enabled = true end
        if v:IsA("BoolValue") or v:IsA("StringValue") then
            local name = string.lower(v.Name)
            if string.find(name, "busy") or string.find(name, "cant") or string.find(name, "nodash") or string.find(name, "nojump") or string.find(name, "usingskill") or string.find(name, "stance") or string.find(name, "active") or string.find(name, "stun") then
                task.spawn(function()
                    local mDelay = tonumber(Config.MacroDelay) or 0.01
                    task.wait(mDelay)
                    if v and v.Parent and v:IsA("BoolValue") then
                        v.Value = false
                    end
                end)
            end
        end
    end)
end

