local function IsAlly(p)
    if p == LP then return true end
    for i = 1, #MCXC.Config.AllyList do if MCXC.Config.AllyList[i] == p.Name then return true end end
    if MCXC.Config.AllyMarines then
        local team = p.Team and s_lower(p.Team.Name)
        if team == "marines" then return true end
    end
    local lpTeam = LP.Team and s_lower(LP.Team.Name)
    local pTeam = p.Team and s_lower(p.Team.Name)
    if lpTeam == "marines" and pTeam == "marines" then return true end
    if lpTeam == "pirates" and pTeam == "pirates" then
        local lpData, pData = LP:FindFirstChild("Data"), p:FindFirstChild("Data")
        if lpData and pData then
            local lpCrew = lpData:FindFirstChild("Crew") and lpData.Crew.Value
            local pCrew = pData:FindFirstChild("Crew") and pData.Crew.Value
            if lpCrew and pCrew and lpCrew == pCrew then return true end
        end
        return p:GetAttribute("Ally") == true or p:FindFirstChild("Ally") ~= nil
    end
    return false
end

