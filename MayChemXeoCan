local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LP = Players.LocalPlayer

local function MayChemXeoCan_IsHolding(char)
    if not char then return false end
    if char:FindFirstChild("Charging") or char:FindFirstChild("Holding") or char:FindFirstChild("UsingSkill") then 
        return true 
    end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool and (tool:FindFirstChild("Charging") or tool:FindFirstChild("Holding")) then
        return true
    end
    return false
end

local function MayChemXeoCan_RandomEquip()
    pcall(function()
        if not LP.Character or not LP.Character:FindFirstChild("Humanoid") then return end
        local validTools = {}
        
        for _, v in pairs(LP.Backpack:GetChildren()) do
            if v:IsA("Tool") and v:FindFirstChild("ToolTip") then
                local tt = string.lower(v.ToolTip.Value or v.ToolTip)
                if string.find(tt, "melee") or string.find(tt, "sword") or string.find(tt, "blox fruit") then
                    table.insert(validTools, v)
                end
            elseif v:IsA("Tool") then
                local name = string.lower(v.Name)
                if not string.find(name, "portal") and not string.find(name, "kabucha") then
                    table.insert(validTools, v)
                end
            end
        end
        
        if #validTools > 0 then
            local randomTool = validTools[math.random(1, #validTools)]
            LP.Character.Humanoid:EquipTool(randomTool)
        end
    end)
end

local function MayChemXeoCan_Core(character)
    character.ChildAdded:Connect(function(v)
        if v:IsA("BoolValue") or v:IsA("StringValue") then
            local name = string.lower(v.Name)
            
            if string.find(name, "stun") then
                task.spawn(function()
                    while v and v.Parent do
                        if v:IsA("BoolValue") and v.Value == true then
                            v.Value = false
                        end
                        task.wait(0.01)
                    end
                end)
                
            elseif string.find(name, "busy") or string.find(name, "cant") then
                task.spawn(function()
                    task.wait(0.03)
                    
                    while character and character.Parent and MayChemXeoCan_IsHolding(character) do
                        task.wait(0.01)
                    end
                    
                    if v and v.Parent and v:IsA("BoolValue") then
                        v.Value = false
                        MayChemXeoCan_RandomEquip()
                    end
                end)
            end
        end
    end)
end

if LP.Character then MayChemXeoCan_Core(LP.Character) end
LP.CharacterAdded:Connect(MayChemXeoCan_Core)

RunService.RenderStepped:Connect(function()
    if LP.Character then
        for _, v in pairs(LP.Character:GetChildren()) do
            if v:IsA("BoolValue") and string.find(string.lower(v.Name), "stun") and v.Value == true then
                v.Value = false
            end
        end
    end
end)
