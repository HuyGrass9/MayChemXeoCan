local function MayChemXeoCan_IsHolding(char)
    if not char then return false end
    local tags = {"Charging", "Holding", "UsingSkill", "Stance", "Active", "Channeling", "Power", "Action"}
    for _, tag in ipairs(tags) do if char:FindFirstChild(tag) then return true end end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then for _, tag in ipairs(tags) do if tool:FindFirstChild(tag) then return true end end end
    return false
end

local function SmartEquip(slot)
    if not LP.Character then return false end
    local hum = LP.Character:FindFirstChild("Humanoid")
    if not hum then return false end
    
    local targetTooltip = ""
    if slot == "1" then targetTooltip = "melee"
    elseif slot == "2" then targetTooltip = "blox fruit"
    elseif slot == "3" then targetTooltip = "sword"
    elseif slot == "4" then targetTooltip = "gun"
    else return false end

    local currentTool = LP.Character:FindFirstChildOfClass("Tool")
    if currentTool and currentTool:FindFirstChild("ToolTip") and string.find(string.lower(currentTool.ToolTip.Value), targetTooltip) then
        return true 
    end

    for _, tool in pairs(LP.Backpack:GetChildren()) do
        if tool:IsA("Tool") and tool:FindFirstChild("ToolTip") and string.find(string.lower(tool.ToolTip.Value), targetTooltip) then
            hum:UnequipTools()
            task.wait(0.05)
            hum:EquipTool(tool)
            task.wait(0.15) 
            return true 
        end
    end
    return false
end

local function ExecuteCombo(comboString, btnRef, strokeRef, colorOn, colorOff)
    strokeRef.Color = Color3.fromRGB(0, 255, 100)
    
    task.spawn(function()
        local str = string.upper(comboString)
        local cDelay = tonumber(Config.ComboDelay) or 0.05
        
        for i = 1, #str do
            local char = string.sub(str, i, i)
            local key = nil
            
            if char == "1" or char == "2" or char == "3" or char == "4" then
                SmartEquip(char)
            elseif char == "Z" then key = Enum.KeyCode.Z
            elseif char == "X" then key = Enum.KeyCode.X
            elseif char == "C" then key = Enum.KeyCode.C
            elseif char == "V" then key = Enum.KeyCode.V
            elseif char == "F" then key = Enum.KeyCode.F
            end
            
            if key then
                VIM:SendKeyEvent(true, key, false, game)
                task.wait(0.02)
                VIM:SendKeyEvent(false, key, false, game)
                
                task.wait(cDelay)
                
                local holdTimeout = tick()
                while MayChemXeoCan_IsHolding(LP.Character) and (tick() - holdTimeout) < 2.5 do
                    RunService.Heartbeat:Wait()
                end
            end
        end
        strokeRef.Color = colorOff
    end)
end

