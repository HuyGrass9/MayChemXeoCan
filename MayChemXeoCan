local function GetToolType(tool)
    if not tool then return "0" end
    local n, v = string.lower(tool.Name), ""; local tt = tool:FindFirstChild("ToolTip"); if tt then v = tostring(tt.Value) end; local vl = string.lower(v)
    if string.find(vl, "melee") or string.find(v, "cận") or string.find(n, "human") or string.find(n, "art") or string.find(n, "claw") or string.find(n, "step") or (string.find(n, "dragon") and string.find(n, "talon")) then return "1" end
    if string.find(vl, "fruit") or string.find(v, "trái") or string.find(v, "quỷ") or (string.find(n, "dragon") and not string.find(n, "talon") and not string.find(n, "trident")) or string.find(n, "kitsune") or string.find(n, "dough") or string.find(n, "leopard") or string.find(n, "buddha") or string.find(n, "portal") then return "2" end
    if string.find(vl, "sword") or string.find(v, "kiếm") or string.find(v, "đao") or string.find(n, "katana") or string.find(n, "blade") or string.find(n, "sword") or string.find(n, "tushita") or string.find(n, "yama") or string.find(n, "cdk") or string.find(n, "trident") then return "3" end
    if string.find(vl, "gun") or string.find(v, "súng") or string.find(v, "pháo") or string.find(n, "rifle") or string.find(n, "kabucha") or string.find(n, "serpent") or string.find(n, "guitar") then return "4" end
    return "0"
end

local function IsSkillBusy(char)
    if not char then return false end
    for _, v in ipairs(char:GetChildren()) do if v:IsA("BoolValue") and v.Value==true and (string.find(string.lower(v.Name), "busy") or string.find(string.lower(v.Name), "using") or string.find(string.lower(v.Name), "cast")) then return true end end
    return false
end

local function ExecuteForceCombo(comboStr, btnRef, stroke, baseColor)
    TweenService:Create(btnRef, TweenInfo.new(0.2), {BackgroundTransparency=0}):Play(); TweenService:Create(stroke, TweenInfo.new(0.2), {Color=Color3.fromRGB(255,255,255), Thickness=3}):Play()
    if Config.AutoHideC and btnRef.Visible then btnRef.Visible=false; task.delay(Config.HideTimer, function() if not getgenv().MacroHidden and ((btnRef==getgenv().ExecBtnC and Config.ShowC) or (btnRef==getgenv().ExecBtnC2 and Config.ShowC2)) then btnRef.Visible=true end end) end
    task.spawn(function()
        task.wait(0.01); local s = string.upper(comboStr); local firstChar = string.sub(s,1,1)
        local cTool = LP.Character:FindFirstChildOfClass("Tool")
        if (firstChar=="1" or firstChar=="2" or firstChar=="3" or firstChar=="4") and cTool and GetToolType(cTool)==firstChar then s=string.sub(s,2) end
        for i=1, #s do
            if getgenv().CancelCombo then break end
            local char = string.sub(s,i,i)
            if char=="1" or char=="2" or char=="3" or char=="4" then
                local tTool = LP.Character:FindFirstChildOfClass("Tool")
                if not tTool or GetToolType(tTool)~=char then
                    local kc = Enum.KeyCode.One; if char=="2" then kc=Enum.KeyCode.Two elseif char=="3" then kc=Enum.KeyCode.Three elseif char=="4" then kc=Enum.KeyCode.Four end
                    VIM:SendKeyEvent(true, kc, false, game); task.wait(0.02); VIM:SendKeyEvent(false, kc, false, game)
                    local w=tick(); while tick()-w<0.3 do if getgenv().CancelCombo then break end; local tk=LP.Character:FindFirstChildOfClass("Tool"); if tk and GetToolType(tk)==char then break end; RunService.Heartbeat:Wait() end; task.wait(0.05)
                end
            elseif char=="Z" or char=="X" or char=="C" or char=="V" or char=="F" then
                local kc = Enum.KeyCode[char]; VIM:SendKeyEvent(true, kc, false, game); task.wait(0.05); VIM:SendKeyEvent(false, kc, false, game)
                local waitReg=tick(); local trg=false; while tick()-waitReg<0.4 do if getgenv().CancelCombo then break end; if IsSkillBusy(LP.Character) then trg=true; break end; RunService.Heartbeat:Wait() end
                if trg then local wAnim=tick(); while IsSkillBusy(LP.Character) and tick()-wAnim<3.0 do if getgenv().CancelCombo then break end; RunService.Heartbeat:Wait() end; task.wait(tonumber(Config.ActionDelay) or 0.1) else task.wait(tonumber(Config.ComboDelay) or 0.05) end
            end
        end
        TweenService:Create(btnRef, TweenInfo.new(0.2), {BackgroundTransparency=0.2}):Play(); TweenService:Create(stroke, TweenInfo.new(0.2), {Color=baseColor, Thickness=2}):Play()
        if btnRef==getgenv().ExecBtnC2 then getgenv().lockC2=false else getgenv().lockC=false end; getgenv().CancelCombo=false
    end)
end

