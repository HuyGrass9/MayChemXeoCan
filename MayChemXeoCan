local isComboing = false
ExecBtn.MouseButton1Click:Connect(function()
    if isComboing then return end
    isComboing = true
    ExecStroke.Color = Color3.fromRGB(0, 255, 100)
    task.spawn(function()
        local str = string.upper(getgenv().MCXC_ComboStr)
        local cDelay = tonumber(getgenv().MCXC_ComboDelay) or 0.2
        
        for i = 1, #str do
            local char = string.sub(str, i, i)
            local key = nil
            local customWait = cDelay
            
            if char == "1" then key = Enum.KeyCode.One; customWait = 0.1
            elseif char == "2" then key = Enum.KeyCode.Two; customWait = 0.1
            elseif char == "3" then key = Enum.KeyCode.Three; customWait = 0.1
            elseif char == "4" then key = Enum.KeyCode.Four; customWait = 0.1
            elseif char == "5" then key = Enum.KeyCode.Five; customWait = 0.1
            elseif char == "Z" then key = Enum.KeyCode.Z
            elseif char == "X" then key = Enum.KeyCode.X
            elseif char == "C" then key = Enum.KeyCode.C
            elseif char == "V" then key = Enum.KeyCode.V
            elseif char == "F" then key = Enum.KeyCode.F
            end
            
            if key then
                VIM:SendKeyEvent(true, key, false, game)
                task.wait(0.02)
                VIM:SendKeyEvent(false, key, false, game)
                task.wait(customWait)
            end
        end
        isComboing = false
        ExecStroke.Color = Color3.fromRGB(255, 50, 50)
    end)
end)

local function MayChemXeoCan_IsHolding(char)
    if not char then return false end
    local tags = {"Charging", "Holding", "UsingSkill", "Stance", "Active", "Channeling", "Power", "Action"}
    for _, tag in ipairs(tags) do
        if char:FindFirstChild(tag) then return true end
    end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then
        for _, tag in ipairs(tags) do
            if tool:FindFirstChild(tag) then return true end
        end
    end
    return false
end

local function MayChemXeoCan_ApexPvP(char)
    char.ChildAdded:Connect(function(v)
        if v:IsA("BoolValue") or v:IsA("StringValue") then
            local name = string.lower(v.Name)
            if string.find(name, "busy") or string.find(name, "cant") or string.find(name, "nodash") or string.find(name, "nojump") then
                task.spawn(function()
                    local mDelay = tonumber(getgenv().MCXC_MacroDelay) or 0.04
                    task.wait(mDelay)
                    while char and char.Parent and MayChemXeoCan_IsHolding(char) do
                        RunService.Heartbeat:Wait()
                    end
                    if v and v.Parent and v:IsA("BoolValue") then
                        v.Value = false
                    end
                end)
            end
        end
    end)
end

if LP.Character then MayChemXeoCan_ApexPvP(LP.Character) end
LP.CharacterAdded:Connect(MayChemXeoCan_ApexPvP)

RunService.RenderStepped:Connect(function()
    if LP.Character then
        local hum = LP.Character:FindFirstChild("Humanoid")
        if hum and hum.WalkSpeed < 35 then
            local isStunned = false
            for _, tag in pairs(LP.Character:GetChildren()) do
                if tag:IsA("BoolValue") and string.find(string.lower(tag.Name), "stun") and tag.Value == true then
                    isStunned = true; break
                end
            end
            if not isStunned and not MayChemXeoCan_IsHolding(LP.Character) then
                hum.WalkSpeed = 35
            end
        end
    end
end)

