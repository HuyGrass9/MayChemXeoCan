local Combat = {}
function Combat.CheckStates(char)
    if typeof(char) ~= "Instance" or not char:IsA("Model") then return false, false end
    local stun, busy = false, false
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("BoolValue") and typeof(v.Value) == "boolean" and v.Value then
            local n = s_lower(v.Name); if s_find(n, "stun") or s_find(n, "cant") then stun = true end; if s_find(n, "busy") or s_find(n, "using") or s_find(n, "cast") then busy = true end
        end
    end; return stun, busy
end

function Combat.SW(t)
    local s = t_tick(); local adj = m_max(0.001, t - (MCXC.State.Ping * 0.6))
    while t_tick() - s < adj do
        local st, _ = Combat.CheckStates(LP.Character)
        if MCXC.State.Status == "IDLE" or st then return false end
        RS.Heartbeat:Wait()
    end; return true
end

