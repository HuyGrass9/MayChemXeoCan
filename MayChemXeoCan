local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VIM = game:GetService("VirtualInputManager")
local LP = Players.LocalPlayer

pcall(function()
    if setfpscap then
        setfpscap(120)
    end
end)

local function MayChemXeoCan_UltimatePvP(character)
    character.ChildAdded:Connect(function(v)
        if v:IsA("BoolValue") or v:IsA("StringValue") then
            local name = string.lower(v.Name)
            if string.find(name, "stun") then
                RunService.Heartbeat:Wait()
                if v.Parent and v:IsA("BoolValue") then
                    v.Value = false
                end
            elseif string.find(name, "busy") or string.find(name, "cant") then
                task.spawn(function()
                    task.wait(0.02)
                    if v.Parent and v:IsA("BoolValue") then
                        v.Value = false
                    end
                end)
            end
        end
    end)
end

if LP.Character then
    MayChemXeoCan_UltimatePvP(LP.Character)
end

LP.CharacterAdded:Connect(function(newChar)
    MayChemXeoCan_UltimatePvP(newChar)
end)

RunService.RenderStepped:Connect(function()
    if LP.Character then
        local hum = LP.Character:FindFirstChild("Humanoid")
        if hum and hum.WalkSpeed < 35 and hum.WalkSpeed > 0 then
            hum.WalkSpeed = 35
        end
        
        for _, v in pairs(LP.Character:GetChildren()) do
            if v:IsA("BoolValue") and string.find(string.lower(v.Name), "stun") and v.Value == true then
                v.Value = false
            end
        end
    end
end)

task.spawn(function()
    while task.wait(0.5) do
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = plr.Character.HumanoidRootPart
                hrp.Size = Vector3.new(20, 20, 20)
                hrp.Transparency = 0.8
                hrp.CanCollide = false
                hrp.Massless = true
            end
        end
    end
end)

local function GetMobileSkillButton(keyName)
    local main = LP.PlayerGui:FindFirstChild("Main")
    if main then
        for _, v in pairs(main:GetDescendants()) do
            if v:IsA("TextLabel") and (v.Text == keyName or string.find(v.Text, "^" .. keyName)) then
                local parent = v.Parent
                while parent and parent ~= main do
                    if parent:IsA("ImageButton") or parent:IsA("TextButton") then
                        return parent
                    end
                    parent = parent.Parent
                end
            end
        end
    end
    return nil
end

local function AutoCastZ()
    local zBtn = GetMobileSkillButton("Z")
    if zBtn then
        pcall(function()
            if getconnections then
                for _, conn in pairs(getconnections(zBtn.Activated)) do conn:Function() end
                for _, conn in pairs(getconnections(zBtn.MouseButton1Click)) do conn:Function() end
                for _, conn in pairs(getconnections(zBtn.TouchTap)) do conn:Function() end
            end
        end)
        
        local absPos = zBtn.AbsolutePosition
        local absSize = zBtn.AbsoluteSize
        local centerX = absPos.X + (absSize.X / 2)
        local centerY = absPos.Y + (absSize.Y / 2) + 36
        
        VIM:SendTouchTapEvent(centerX, centerY, false, game)
        task.wait(0.05)
        VIM:SendTouchTapEvent(centerX, centerY, true, game)
    end
    
    VIM:SendKeyEvent(true, Enum.KeyCode.Z, false, game)
    task.wait(0.05)
    VIM:SendKeyEvent(false, Enum.KeyCode.Z, false, game)
end

task.spawn(function()
    while task.wait(1) do
        pcall(function()
            local xBtn = GetMobileSkillButton("X")
            if xBtn and not xBtn:FindFirstChild("MayChemMacroX") then
                local tag = Instance.new("BoolValue")
                tag.Name = "MayChemMacroX"
                tag.Parent = xBtn
                
                local function OnXTriggered()
                    local tool = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
                    if tool and (tool.Name == "Dark Blade" or string.find(tool.Name, "Yoru")) then
                        task.spawn(function()
                            task.wait(0.12)
                            AutoCastZ()
                        end)
                    end
                end
                
                xBtn.Activated:Connect(OnXTriggered)
                xBtn.MouseButton1Click:Connect(OnXTriggered)
                if xBtn.TouchTap then
                    xBtn.TouchTap:Connect(OnXTriggered)
                end
            end
        end)
    end
end)
