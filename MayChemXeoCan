local function CreateActionBtn(name, yPos, color, showKey)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, Config.BtnSize, 0, Config.BtnSize)
    btn.Position = UDim2.new(0.8, 0, yPos, 0)
    btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    btn.BackgroundTransparency = 0.2
    btn.Text = name
    btn.TextColor3 = color
    btn.Font = Enum.Font.GothamBlack
    btn.TextSize = math.clamp(Config.BtnSize * 0.4, 15, 45)
    btn.Visible = Config[showKey]
    btn.Active = true
    btn.Selectable = false
    btn.Draggable = Config.SetupMode
