function LagFixer.ProcessObject(v)
    if not v or not v:IsDescendantOf(workspace) then return end
    if LP.Character and v:IsDescendantOf(LP.Character) then return end
    for _, plr in pairs(MCXC.State.ActivePlayers) do
        if plr.Character and v:IsDescendantOf(plr.Character) then return end
    end
    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            for _, child in ipairs(v:GetChildren()) do
                if child:IsA("Decal") or child:IsA("Texture") then child:Destroy() end
                if child:IsA("SpecialMesh") then child.TextureId = "" end
            end
        elseif v:IsA("ParticleEmitter") then
            local isSkillEffect = false
            local parent = v.Parent
            while parent do
                if parent:IsA("Tool") or parent:IsA("Model") and parent:FindFirstChild("Humanoid") then isSkillEffect = true break end
                parent = parent.Parent
            end
            local n = s_lower(v.Name)
            if s_find(n, "smoke") or s_find(n, "fog") or s_find(n, "fire") or s_find(n, "spark") then
                v.Rate = v.Rate * 0.1
            elseif isSkillEffect then
                v.Rate = v.Rate * 0.6
            else
                v.Rate = v.Rate * 0.3
            end
            if v.Size then
                local kp = v.Size.Keypoints
                if #kp > 0 then v.Size = NS(kp[1].Value * 0.7) end
            end
            v.LightEmission = (v.LightEmission or 1) * 0.4
        elseif v:IsA("Trail") or v:IsA("Beam") then
            local isSkillEffect = false
            local parent = v.Parent
            while parent do
                if parent:IsA("Tool") or parent:IsA("Model") and parent:FindFirstChild("Humanoid") then isSkillEffect = true break end
                parent = parent.Parent
            end
            if not isSkillEffect then
                v.Transparency = NS(0.7)
                v.Width0 = v.Width0 * 0.5
                v.Width1 = v.Width1 * 0.5
            end
        elseif v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("ColorCorrectionEffect") or v:IsA("Atmosphere") or v:IsA("Sky") or v:IsA("Clouds") then
            v.Enabled = false
        end
    end)
end
