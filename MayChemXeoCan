function Combat.ExecuteCombo(comboId, comboStr, strUI, col, onEnd)
    if not HasCombatAccess() then return end
    if MCXC.State.CurrentCombo then return end
    MCXC.State.CurrentCombo = comboId; MCXC.State.ComboCancelRequested = false
    CameraLock.Enable()
    t_spawn(function()
        local seq = s_upper(comboStr); local failed, failReason = false, ""
        Utils.Tween(strUI, {Thickness = 2.5, Color = Theme.Text}, 0.05)
        for step = 1, #seq do
            if MCXC.State.ComboCancelRequested then failed = true; failReason = "CANCELLED"; break end
            if LP.Character and Combat.IsStunned(LP.Character) then Combat.WaitForStunEnd(LP.Character) end
            local key = s_sub(seq, step, step)
            if s_match(key, "[1-4]") then
                if not Combat.SwitchToTool(key) then failed = true; failReason = "TOOL SWITCH FAIL"; break end
                local pingDelay = 0.1 + (MCXC.State.Ping / 2)
                t_wait(pingDelay)
            elseif s_match(key, "[ZXCVF]") then
                local kc = Enum.KeyCode[key]
                local currentType = GetCurrentToolType()
                local holdTime = 0
                if MCXC.Config.HoldEnabled and currentType then holdTime = MCXC.Config.Hold_["Hold_" .. currentType .. key] or 0 end
                local tool = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
                if not tool then failed = true; failReason = "NO TOOL"; break end
                VIM:SendKeyEvent(true, kc, false, game)
                if holdTime > 0 then
                    local holdStart = t_tick()
                    repeat t_wait(); if LP.Character and Combat.IsStunned(LP.Character) then break end; if MCXC.State.ComboCancelRequested then break end until t_tick() - holdStart >= holdTime
                end
                if not Combat.WaitForSkillActivation(tool, key) then
                    VIM:SendKeyEvent(false, kc, false, game); VIM:SendKeyEvent(true, kc, false, game)
                    if not Combat.WaitForSkillActivation(tool, key) then
                        VIM:SendKeyEvent(false, kc, false, game); failed = true; failReason = "SKILL NOT ACTIVATED"; break
                    end
                end
                VIM:SendKeyEvent(false, kc, false, game)
                while LP.Character and Combat.CheckBusy(LP.Character) do if MCXC.State.ComboCancelRequested then break end; t_wait() end
                local pingDelay = 0.03 + (MCXC.State.Ping / 4)
                t_wait(pingDelay)
            end
        end
        CameraLock.ForceRestore()
        if failed then MCXC.State.Status = "FAIL: " .. failReason; Utils.Tween(strUI, {Thickness = 2.5, Color = Theme.Danger}, 0.1); t_delay(0.3, function() Utils.Tween(strUI, {Thickness = 1.5, Color = col}, 0.2) end)
        else MCXC.State.Status = "DONE: " .. comboId; Utils.Tween(strUI, {Thickness = 1.5, Color = col}, 0.2) end
        MCXC.State.CurrentCombo = nil
        if onEnd then onEnd() end
        if MCXC.State.ComboQueue then ProcessQueue() end
    end)
end
