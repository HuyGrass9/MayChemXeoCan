local function ClearStun(char)
    if not char then return end
    local badTags = {"busy", "cant", "stun", "nodash", "nojump", "usingskill"}
    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("BoolValue") and v.Value == true then
            local n = string.lower(v.Name)
            for _, tag in ipairs(badTags) do
                if string.find(n, tag) then v.Value = false end
            end
        end
    end
end

local function SmartEquipVirtual(slotStr)
    local kc
    if slotStr == "1" then kc = Enum.KeyCode.One
    elseif slotStr == "2" then kc = Enum.KeyCode.Two
    elseif slotStr == "3" then kc = Enum.KeyCode.Three
    elseif slotStr == "4" then kc = Enum.KeyCode.Four
    else return end
    
    VIM:SendKeyEvent(true, kc, false, game)
    task.wait(0.01)
    VIM:SendKeyEvent(false, kc, false, game)
    
    local w = tick()
    while not LP.Character:FindFirstChildOfClass("Tool") and tick() - w < 0.5 do
        RunService.Heartbeat:Wait()
    end
    task.wait(0.1)
end

local function FireAICombo(str, stroke, baseColor)
    stroke.Color = Color3.fromRGB(255, 255, 255)
    task.spawn(function()
        local s = string.upper(str)
        local keyDelay = tonumber(Config.ComboDelay) or 0.2
        local actDelay = tonumber(Config.ActionDelay) or 0.4
        
        for i = 1, #s do
            local char = string.sub(s, i, i)
            if char == "1" or char == "2" or char == "3" or char == "4" then
                SmartEquipVirtual(char)
            elseif char == "Z" or char == "X" or char == "C" or char == "V" or char == "F" then
                ClearStun(LP.Character)
                local kc = Enum.KeyCode[char]
                
                VIM:SendKeyEvent(true, kc, false, game)
                task.wait(keyDelay)
                VIM:SendKeyEvent(false, kc, false, game)
                
                local waitStart = tick()
                local isAnim = false
                while tick() - waitStart < 0.8 do
                    RunService.Heartbeat:Wait()
                    local hasTag = false
                    for _, v in ipairs(LP.Character:GetDescendants()) do
                        if v:IsA("BoolValue") and v.Value == true and (string.find(string.lower(v.Name), "busy") or string.find(string.lower(v.Name), "usingskill")) then
                            hasTag = true
                            isAnim = true
                            break
                        end
                    end
                    if isAnim and not hasTag then break end
                end
                
                ClearStun(LP.Character)
                task.wait(actDelay)
            end
        end
        stroke.Color = baseColor
    end)
end

