function MCXC.Combat.ExecuteCombo(comboId, comboStr, strUI, col, onEnd)
    if MCXC.State.Status == "CASTING" then return end
    MCXC.State.Status = "CASTING"; MCXC.State.CurrentCombo = comboId; MCXC.Utils.UpdateStatus()
    MCXC.Utils.Tween(strUI, {Thickness=3, Color=Theme.Text}, 0.05)
    t_spawn(function()
        local seq = s_upper(comboStr); local cT = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
        local firstKey = s_sub(seq, 1, 1)
        if s_match(firstKey, "[1-4]") and cT and GetToolType(cT) == firstKey then seq = s_sub(seq, 2) end
        local curWepType = "0"; if cT then curWepType = GetToolType(cT) end
        local currentHeldKey, comboFailed = nil, false
        for i = 1, #seq do
            local st, _ = MCXC.Combat.CheckStates(LP.Character); if MCXC.State.Status == "IDLE" or st then comboFailed = true; break end
            local key = s_sub(seq, i, i)
            if s_match(key, "[1-4]") then
                curWepType = key; local tT = LP.Character:FindFirstChildOfClass("Tool")
                if not tT or GetToolType(tT) ~= key then
                    local kc = Enum.KeyCode.One; if key=="2" then kc=Enum.KeyCode.Two elseif key=="3" then kc=Enum.KeyCode.Three elseif key=="4" then kc=Enum.KeyCode.Four end
                    VIM:SendKeyEvent(true, kc, false, game); RS.Heartbeat:Wait(); VIM:SendKeyEvent(false, kc, false, game)
                    local w = t_tick(); while t_tick()-w < 0.4 do if MCXC.State.Status == "IDLE" then break end; local tk = LP.Character:FindFirstChildOfClass("Tool"); if tk and GetToolType(tk)==key then break end; RS.Heartbeat:Wait() end
                end
            elseif s_match(key, "[ZXCVF]") then
                local kc = Enum.KeyCode[key]; currentHeldKey = kc; VIM:SendKeyEvent(true, kc, false, game)
                local hold = MCXC.Config.HoldEnabled and (MCXC.Config["Hold_"..curWepType..key] or 0) or 0
                if not MCXC.Combat.SW(m_max(0.01, hold)) then comboFailed = true; break end
                VIM:SendKeyEvent(false, kc, false, game); currentHeldKey = nil
                local wR, fired = t_tick(), false; while t_tick()-wR < (MCXC.State.Ping + 0.15) do local s, b = MCXC.Combat.CheckStates(LP.Character); if s then break end; if b then fired = true; break end; RS.Heartbeat:Wait() end
                if fired then local wA = t_tick(); while t_tick()-wA < 3.0 do local s, b = MCXC.Combat.CheckStates(LP.Character); if MCXC.State.Status == "IDLE" or s or not b then break end; RS.Heartbeat:Wait() end end
                if MCXC.State.Status == "IDLE" then comboFailed = true; break end
                MCXC.Combat.SW(0.01)
            end
        end
        if currentHeldKey then pcall(function() VIM:SendKeyEvent(false, currentHeldKey, false, game) end) end
        MCXC.State.Status = "IDLE"; MCXC.Utils.UpdateStatus()
        if comboFailed then MCXC.Utils.Tween(strUI, {Thickness=3, Color=Theme.Danger}, 0.1); t_delay(0.3, function() if MCXC.State.Status == "IDLE" then MCXC.Utils.Tween(strUI, {Thickness=1.5, Color=col}, 0.2) end end)
        else MCXC.Utils.Tween(strUI, {Thickness=1.5, Color=col}, 0.2) end
        if onEnd then onEnd() end
    end)
end
