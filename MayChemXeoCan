local function IsBusy(char) if not char then return false end; for _, v in ipairs(char:GetChildren()) do if v:IsA("BoolValue") and v.Value==true and (string.find(string.lower(v.Name), "busy") or string.find(string.lower(v.Name), "using") or string.find(string.lower(v.Name), "cast")) then return true end end; return false end

local function ExCombo(comboStr, btnRef, stroke, baseColor)
    TweenService:Create(btnRef, TweenInfo.new(0.2), {BackgroundTransparency=0.1}):Play(); TweenService:Create(stroke, TweenInfo.new(0.2), {Color=Color3.fromRGB(255,255,255), Thickness=2.5}):Play()
    if Config.AutoHideC and btnRef.Visible then btnRef.Visible=false; task.delay(Config.HideTimer, function() if not getgenv().MacroHidden and ((btnRef==getgenv().ExecBtnC and Config.ShowC) or (btnRef==getgenv().ExecBtnC2 and Config.ShowC2)) then btnRef.Visible=true end end) end
    task.spawn(function()
        task.wait(0.01); local s = string.upper(comboStr); local first = string.sub(s,1,1); local cT = LP.Character:FindFirstChildOfClass("Tool")
        if (first=="1" or first=="2" or first=="3" or first=="4") and cT and GetToolType(cT)==first then s=string.sub(s,2) end
        for i=1, #s do
            if getgenv().CancelCombo then break end; local char = string.sub(s,i,i)
            if char=="1" or char=="2" or char=="3" or char=="4" then
                local tT = LP.Character:FindFirstChildOfClass("Tool")
                if not tT or GetToolType(tT)~=char then
                    local kc = Enum.KeyCode.One; if char=="2" then kc=Enum.KeyCode.Two elseif char=="3" then kc=Enum.KeyCode.Three elseif char=="4" then kc=Enum.KeyCode.Four end
                    VIM:SendKeyEvent(true, kc, false, game); task.wait(0.02); VIM:SendKeyEvent(false, kc, false, game)
                    local w=tick(); while tick()-w<0.3 do if getgenv().CancelCombo then break end; local tk=LP.Character:FindFirstChildOfClass("Tool"); if tk and GetToolType(tk)==char then break end; RunService.Heartbeat:Wait() end; task.wait(0.05)
                end
            elseif char=="Z" or char=="X" or char=="C" or char=="V" or char=="F" then
                local kc = Enum.KeyCode[char]; VIM:SendKeyEvent(true, kc, false, game); task.wait(0.05); VIM:SendKeyEvent(false, kc, false, game)
                local wR=tick(); local trg=false; while tick()-wR<0.4 do if getgenv().CancelCombo then break end; if IsBusy(LP.Character) then trg=true; break end; RunService.Heartbeat:Wait() end
                if trg then local wA=tick(); while IsBusy(LP.Character) and tick()-wA<3.0 do if getgenv().CancelCombo then break end; RunService.Heartbeat:Wait() end; task.wait(tonumber(Config.ActionDelay) or 0.1) else task.wait(tonumber(Config.ComboDelay) or 0.05) end
            end
        end
        TweenService:Create(btnRef, TweenInfo.new(0.2), {BackgroundTransparency=0.3}):Play(); TweenService:Create(stroke, TweenInfo.new(0.2), {Color=baseColor, Thickness=1.5}):Play()
        if btnRef==getgenv().ExecBtnC2 then getgenv().lockC2=false else getgenv().lockC=false end; getgenv().CancelCombo=false
    end)
end

getgenv().ExecBtnC.InputBegan:Connect(function(inp) if (inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseButton1) and not getgenv().SetupMode and not getgenv().lockC then getgenv().lockC=true; ExCombo(Config.ComboC, getgenv().ExecBtnC, getgenv().StrokeC, Color3.fromRGB(255,80,80)) end end)
getgenv().ExecBtnC2.InputBegan:Connect(function(inp) if (inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseButton1) and not getgenv().SetupMode and not getgenv().lockC2 then getgenv().lockC2=true; ExCombo(Config.ComboC2, getgenv().ExecBtnC2, getgenv().StrokeC2, Color3.fromRGB(80,200,255)) end end)
getgenv().ExecBtnX.InputBegan:Connect(function(inp) if (inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseButton1) and not getgenv().SetupMode then getgenv().CancelCombo=true; getgenv().lockC=false; getgenv().lockC2=false; TweenService:Create(getgenv().ExecBtnX, TweenInfo.new(0.1), {BackgroundTransparency=0.1}):Play(); task.delay(0.2, function() TweenService:Create(getgenv().ExecBtnX, TweenInfo.new(0.2), {BackgroundTransparency=0.3}):Play() end) end end)

-- LOCK BUTTON (STICKY TARGETING)
getgenv().ExecBtnAim.InputBegan:Connect(function(inp)
    if (inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseButton1) and not getgenv().SetupMode then
        local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart"); if not myRoot then return end
        local near, mD = nil, math.huge
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health>0 then
                local d=(p.Character.HumanoidRootPart.Position-myRoot.Position).Magnitude
                if d<mD then mD=d; near=p end
            end
        end
        if near then
            getgenv().LockedTarget = near
            getgenv().LockEndTime = tick() + (tonumber(Config.LockTime) or 1.5)
        end
    end
end)

TouchZone.InputBegan:Connect(function(inp) if (inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseButton1) and not getgenv().SetupMode then local cam = workspace.CurrentCamera; local r = cam:ScreenPointToRay(inp.Position.X, inp.Position.Y); local hP = r.Origin + r.Direction*1000; local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if myR then myR.CFrame = CFrame.lookAt(myR.Position, Vector3.new(hP.X, myR.Position.Y, hP.Z)); if not getgenv().lockC then getgenv().lockC=true; ExCombo(Config.ComboC, getgenv().ExecBtnC, getgenv().StrokeC, Color3.fromRGB(255,80,80)) end end end end)

RunService.Heartbeat:Connect(function()
    pcall(function()
        -- GHOST DESYNC CAMERA SMOOTH LERP
        if getgenv().LockedTarget and tick() < (getgenv().LockEndTime or 0) then
            local tChar = getgenv().LockedTarget.Character
            if tChar and tChar:FindFirstChild("HumanoidRootPart") and tChar:FindFirstChild("Humanoid") and tChar.Humanoid.Health > 0 then
                local cam = workspace.CurrentCamera; local eP = tChar.HumanoidRootPart.Position; local r = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                cam.CFrame = cam.CFrame:Lerp(CFrame.lookAt(cam.CFrame.Position, eP), 0.3)
                if r then r.CFrame = r.CFrame:Lerp(CFrame.lookAt(r.Position, Vector3.new(eP.X, r.Position.Y, eP.Z)), 0.4) end
            else
                getgenv().LockedTarget = nil
            end
        else
            getgenv().LockedTarget = nil
        end

        if LP.Character then
            if Config.AntiStun then for _,v in ipairs(LP.Character:GetChildren()) do if v:IsA("BoolValue") and v.Value==true and (string.find(string.lower(v.Name),"stun") or string.find(string.lower(v.Name),"cant") or string.find(string.lower(v.Name),"nodash")) then v.Value=false end end end
            local isMv = LP.Character:FindFirstChild("Humanoid") and LP.Character.Humanoid.MoveDirection.Magnitude > 0
            if Config.FakeLag and isMv and not (getgenv().lockC or getgenv().lockC2) and LP.Character:FindFirstChild("HumanoidRootPart") then
                lagTick=lagTick+1; if lagTick>=(tonumber(Config.FakeLagTick) or 3) then local hr=LP.Character.HumanoidRootPart; ghostCF=hr.CFrame; hr.CFrame=ghostCF*CFrame.new(math.random(-150,150), 0, math.random(-150,150)); lagTick=0 end
            else lagTick=0 end
            
            local myR = LP.Character:FindFirstChild("HumanoidRootPart"); local nearestPlr, minD = nil, math.huge
            for _,p in ipairs(Players:GetPlayers()) do if p~=LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health>0 then local d=(p.Character.HumanoidRootPart.Position-myR.Position).Magnitude; if d<minD then minD=d; nearestPlr=p end end end
            
            if Config.ShowMap and not getgenv().MacroHidden then
                for _,v in ipairs(DotsContainer:GetChildren()) do v:Destroy() end
                local cam = workspace.CurrentCamera
                if myR then
                    local cF2 = Vector2.new(cam.CFrame.LookVector.X, cam.CFrame.LookVector.Z).Unit; local cR2 = Vector2.new(cam.CFrame.RightVector.X, cam.CFrame.RightVector.Z).Unit
                    for _,p in ipairs(Players:GetPlayers()) do
                        if p~=LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health>0 then
                            local d3 = p.Character.HumanoidRootPart.Position - myR.Position; local dst = d3.Magnitude; local maxR = tonumber(Config.MapRange) or 700
                            if dst<=maxR then
                                local of2 = Vector2.new(d3.X, d3.Z); local sc = ((tonumber(Config.MapSize) or 130)/2)/maxR; local uX = of2:Dot(cR2)*sc; local uY = -of2:Dot(cF2)*sc
                                local dot = Instance.new("Frame", DotsContainer); dot.Size=UDim2.new(0,6,0,6); dot.BackgroundColor3 = (p==nearestPlr) and Color3.fromRGB(255,255,0) or Color3.fromRGB(255,50,50); dot.Position=UDim2.new(0.5,uX-3,0.5,uY-3); Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0); dot.ZIndex=4
                            end
                        end
                    end
                end
            end

            for _,p in ipairs(Players:GetPlayers()) do
                if p~=LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local rt = p.Character.HumanoidRootPart; local dst = (rt.Position-myR.Position).Magnitude; local isNear = (p == nearestPlr)
                    if Config.Hitbox and not getgenv().MacroHidden then local hs=tonumber(Config.HitboxSize) or 15; rt.Size=Vector3.new(hs,hs,hs); rt.Transparency=0.8; rt.CanCollide=false else if rt.Size.X>5 then rt.Size=Vector3.new(2,2,1); rt.Transparency=1 end end
                    local espG = rt:FindFirstChild("ESP_"..p.Name)
                    if Config.ESP and dst<=(tonumber(Config.RenderDistance) or 1500) and not getgenv().MacroHidden then
                        if not espG then espG=Instance.new("BillboardGui",rt); espG.Name="ESP_"..p.Name; espG.Size=UDim2.new(0,200,0,50); espG.StudsOffset=Vector3.new(0,3,0); espG.AlwaysOnTop=true; local tx=Instance.new("TextLabel",espG); tx.Name="TextNode"; tx.Size=UDim2.new(1,0,1,0); tx.BackgroundTransparency=1; tx.Font=Enum.Font.GothamBold; tx.TextSize=11; tx.TextStrokeTransparency=0.5 end
                        local hp,mhp=0,0; pcall(function() hp=math.floor(p.Character.Humanoid.Health); mhp=math.floor(p.Character.Humanoid.MaxHealth) end); local w=p.Character:FindFirstChildOfClass("Tool"); w = w and w.Name or "None"
                        local tn=espG:FindFirstChild("TextNode"); if tn then tn.Text=string.format("%s\nHP: %d/%d | W: %s\nDist: %dm", p.Name, hp, mhp, string.sub(w,1,15), math.floor(dst)); tn.TextColor3=isNear and Color3.fromRGB(255,255,0) or Color3.fromRGB(255,255,255) end
                    elseif espG then espG:Destroy() end
                    local lin = rt:FindFirstChild("TracerLine_"..p.Name)
                    if Config.ViewTracer and dst<=(tonumber(Config.RenderDistance) or 1500) and not getgenv().MacroHidden then
                        if not lin then lin=Instance.new("LineHandleAdornment",rt); lin.Name="TracerLine_"..p.Name; lin.Adornee=rt; lin.Thickness=5; lin.Length=50; lin.ZIndex=5; lin.Transparency=0.2; lin.AlwaysOnTop=true end
                        lin.Color3=isNear and Color3.fromRGB(255,255,0) or Color3.fromRGB(0,255,150)
                    elseif lin then lin:Destroy() end
                end
            end
        end
    end)
end)
