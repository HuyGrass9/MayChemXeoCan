local OrderLoop = nil
function StartOrder()
    if OrderLoop then return end
    if not BuyShopGoodsRE then Logger:Add("LOI: Khong tim thay BuyShopGoodsRE"); return end
    OrderLoop = t_spawn(function()
        while Config.OrderEnabled do
            local stockData = {}
            pcall(function()
                local productFolder = workspace.Resources:FindFirstChild("Product")
                if productFolder then
                    for _, box in ipairs(productFolder:GetChildren()) do
                        if box:IsA("Model") and box.Name:find("Box") then
                            local itemName = box.Name:gsub("Box", "")
                            stockData[itemName] = (stockData[itemName] or 0) + 1
                        end
                    end
                end
            end)
            for itemName, count in pairs(stockData) do
                if count < Config.Threshold then
                    local orderList = {}
                    orderList[itemName] = {}
                    pcall(function() BuyShopGoodsRE:FireServer(orderList, "Product") end)
                    Logger:Add("Order: " .. itemName .. " (con " .. count .. ")")
                    t_wait(0.1)
                end
            end
            t_wait(2)
        end
    end)
end
function StopOrder() if OrderLoop then task.cancel(OrderLoop); OrderLoop = nil end end

Tab2:CreateToggle("Auto Order", "OrderEnabled", function(v)
    Logger:Add("Auto Order: " .. (v and "ON" or "OFF"))
    if v then StartOrder() else StopOrder() end
end)
Tab2:CreateSlider("Nguong thieu", 1, 20, 5, "Threshold", function(v) Logger:Add("Threshold: " .. v) end)

local ShelveLoop = nil
function StartShelve()
    if ShelveLoop then return end
    if not ScreenRE then Logger:Add("LOI: Khong tim thay ScreenRE"); return end
    ShelveLoop = t_spawn(function()
        while Config.ShelveEnabled do
            local productFolder = workspace.Resources and workspace.Resources:FindFirstChild("Product")
            if not productFolder then t_wait(1); continue end
            local boxes = {}
            for _, obj in ipairs(productFolder:GetChildren()) do
                if obj:IsA("Model") and obj.Name:find("Box") then table.insert(boxes, obj) end
            end
            local shelves = {}
            local building = workspace.Resources:FindFirstChild("Building")
            if building then
                for _, shelfType in ipairs({"DryRack", "Fridge"}) do
                    local shelfModel = building:FindFirstChild(shelfType)
                    if shelfModel and shelfModel:IsA("Model") then
                        local detectorFolder = shelfModel:FindFirstChild("DetectorFolder")
                        if detectorFolder then
                            for _, detector in ipairs(detectorFolder:GetChildren()) do
                                if detector:IsA("BasePart") then
                                    table.insert(shelves, {shelf = shelfModel, detector = detector})
                                end
                            end
                        end
                    end
                end
            end
            if #boxes > 0 and #shelves > 0 then
                local box = boxes[1]
                local bestShelf = nil; local minDist = math.huge; local boxPos = box:GetPivot().Position
                for _, shelfData in ipairs(shelves) do
                    local dist = (shelfData.detector.Position - boxPos).Magnitude
                    if dist < minDist then minDist = dist; bestShelf = shelfData end
                end
                if bestShelf then
                    pcall(function() ScreenRE:FireServer("TakeBox", box) end)
                    t_wait(0.3)
                    local carriedFolder = workspace.Resources:FindFirstChild("Carried")
                    if carriedFolder then
                        local playerCarry = carriedFolder:FindFirstChild(LP.Name)
                        if playerCarry then
                            local carriedBox = playerCarry:FindFirstChild(box.Name)
                            if carriedBox then
                                pcall(function() ScreenRE:FireServer("PutProduct", carriedBox, bestShelf.detector, bestShelf.shelf) end)
                                Logger:Add("Len ke: " .. box.Name .. " -> " .. bestShelf.shelf.Name)
                            else
                                pcall(function() ScreenRE:FireServer("DropBox") end)
                                Logger:Add("Khong tim thay box trong Carried, DropBox")
                            end
                        else
                            pcall(function() ScreenRE:FireServer("DropBox") end)
                            Logger:Add("Khong tim thay Carried, DropBox")
                        end
                    end
                end
            end
            t_wait(Config.ShelveDelay)
        end
    end)
end
function StopShelve() if ShelveLoop then task.cancel(ShelveLoop); ShelveLoop = nil end end

Tab3:CreateToggle("Auto Shelve", "ShelveEnabled", function(v)
