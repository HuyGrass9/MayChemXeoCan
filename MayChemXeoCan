local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LP = Players.LocalPlayer

pcall(function()
    if setfpscap then
        setfpscap(120)
    end
end)

local function MayChemXeoCan_IsHolding(char)
    if not char then return false end
    if char:FindFirstChild("Charging") then return true end
    if char:FindFirstChild("Holding") then return true end
    if char:FindFirstChild("UsingSkill") then return true end
    
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then
        if tool:FindFirstChild("Charging") or tool:FindFirstChild("Holding") then
            return true
        end
    end
    return false
end

local function MayChemXeoCan_PerfectPvP(character)
    character.ChildAdded:Connect(function(v)
        if v:IsA("BoolValue") or v:IsA("StringValue") then
            local name = string.lower(v.Name)
            if string.find(name, "busy") or string.find(name, "stun") or string.find(name, "cant") then
                task.spawn(function()
                    task.wait(0.05)
                    
                    while character and character.Parent and v and v.Parent and MayChemXeoCan_IsHolding(character) do
                        task.wait(0.01)
                    end
                    
                    task.wait(0.05)
                    
                    if v and v.Parent and v:IsA("BoolValue") then
                        v.Value = false
                    end
                end)
            end
        end
    end)
end

if LP.Character then
    MayChemXeoCan_PerfectPvP(LP.Character)
end

LP.CharacterAdded:Connect(function(newChar)
    MayChemXeoCan_PerfectPvP(newChar)
end)

RunService.Stepped:Connect(function()
    if LP.Character then
        local hum = LP.Character:FindFirstChild("Humanoid")
        if hum and hum.WalkSpeed < 16 and hum.WalkSpeed > 0 then
            if not MayChemXeoCan_IsHolding(LP.Character) then
                hum.WalkSpeed = 16
            end
        end
    end
end)
