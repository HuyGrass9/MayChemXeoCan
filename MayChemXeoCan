local function GetToolType(tool) if not tool then return "0" end; local n, v = string.lower(tool.Name), ""; local tt = tool:FindFirstChild("ToolTip"); if tt then v = string.lower(tostring(tt.Value)) end; for i=1,4 do for _,k in ipairs(tArr[i]) do if string.find(n,k) or string.find(v,k) then return tostring(i) end end end; return "0" end

local function TargetSystem()
    local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart"); if not myR then return nil end
    local cam = workspace.CurrentCamera; local bestTarget, minD = nil, math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health>0 then
            local pos, vis = cam:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if vis then
                local dist = (p.Character.HumanoidRootPart.Position - myR.Position).Magnitude
                if dist < 300 and dist < minD then minD = dist; bestTarget = p end
            end
        end
    end
    State.Target = bestTarget
    return bestTarget
end

local function AimEngine()
    if not Config.AutoLock then return end
    local t = TargetSystem()
    if t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") then
        local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart"); if not myR then return end
        local tR = t.Character.HumanoidRootPart; local ping = GetPing()
        local predPos = tR.Position + (tR.Velocity * (ping + Config.PredictionFactor))
        local cPos = myR.Position; local look = CFrame.lookAt(cPos, Vector3.new(predPos.X, cPos.Y, predPos.Z))
        myR.CFrame = look
    end
end

local function ProcessCombo(comboStr, btnRef, stroke, baseColor)
    TweenService:Create(btnRef, TweenInfo.new(0.2), {BackgroundTransparency=0.1}):Play(); TweenService:Create(stroke, TweenInfo.new(0.2), {Color=Color3.fromRGB(255,255,255), Thickness=2.5, Transparency=0}):Play()
    task.spawn(function()
        task.wait(0.01); local s = string.upper(comboStr); local first = string.sub(s,1,1); local cT = LP.Character:FindFirstChildOfClass("Tool")
        if tonumber(first) and cT and GetToolType(cT)==first then s=string.sub(s,2) end
        for i=1, #s do
            if getgenv().CancelCombo then break end; local char = string.sub(s,i,i)
            if tonumber(char) then
                local tT = LP.Character:FindFirstChildOfClass("Tool"); if not tT or GetToolType(tT)~=char then
                    local kc = Enum.KeyCode.One; if char=="2" then kc=Enum.KeyCode.Two elseif char=="3" then kc=Enum.KeyCode.Three elseif char=="4" then kc=Enum.KeyCode.Four end
                    VIM:SendKeyEvent(true, kc, false, game); task.wait(HumanizeDelay(0.02)); VIM:SendKeyEvent(false, kc, false, game); local w=tick(); while tick()-w<0.3 do if getgenv().CancelCombo then break end; local tk=LP.Character:FindFirstChildOfClass("Tool"); if tk and GetToolType(tk)==char then break end; task.wait() end; task.wait(HumanizeDelay(0.02))
                end
            elseif string.match(char, "[ZXCVF]") then
                AimEngine(); local kc = Enum.KeyCode[char]; VIM:SendKeyEvent(true, kc, false, game); task.wait(HumanizeDelay(0.05)); VIM:SendKeyEvent(false, kc, false, game)
                task.wait(HumanizeDelay(tonumber(Config.ComboDelay) or 0.05))
            end
        end
        TweenService:Create(btnRef, TweenInfo.new(0.2), {BackgroundTransparency=0.3}):Play(); TweenService:Create(stroke, TweenInfo.new(0.2), {Color=baseColor, Thickness=1.5, Transparency=0.2}):Play()
        if btnRef==getgenv().ExecBtnC2 then getgenv().lockC2=false else getgenv().lockC=false end; getgenv().CancelCombo=false
    end)
end

