local function CreateTab(name, yPos, isActive)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 40)
    btn.Position = UDim2.new(0, 0, 0, yPos)
    btn.BackgroundTransparency = isActive and 0.9 or 1
    btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    btn.Text = "   " .. name
    btn.TextColor3 = isActive and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(130, 130, 140)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.BorderSizePixel = 0
    btn.Parent = Sidebar
    
    local indicator = Instance.new("Frame")
    indicator.Size = UDim2.new(0, 3, 1, -16)
    indicator.Position = UDim2.new(0, 0, 0, 8)
    indicator.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
    indicator.BorderSizePixel = 0
    indicator.Visible = isActive
    indicator.Parent = btn
    
    local frame = Instance.new("ScrollingFrame")
    frame.Size = UDim2.new(1, -10, 1, -10)
    frame.Position = UDim2.new(0, 5, 0, 5)
    frame.BackgroundTransparency = 1
    frame.Visible = isActive
    frame.ScrollBarThickness = 2
    frame.CanvasSize = UDim2.new(0, 0, 0, 450)
    frame.Parent = ContentArea
    
    TabBtns[name] = {Btn = btn, Ind = indicator}
    TabFrames[name] = frame
    
    btn.MouseButton1Click:Connect(function()
        for k, v in pairs(TabFrames) do v.Visible = (k == name) end
        for k, v in pairs(TabBtns) do
            v.Ind.Visible = (k == name)
            TweenService:Create(v.Btn, TweenInfo.new(0.2), {
                BackgroundTransparency = (k == name) and 0.9 or 1,
                TextColor3 = (k == name) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(130, 130, 140)
            }):Play()
        end
    end)
    return frame
end

