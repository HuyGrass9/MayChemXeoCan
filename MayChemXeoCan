RunService.Heartbeat:Connect(function()
    pcall(function()
        local now = tick(); local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not myR then return end
        
        local unl = (MCXC.Config.PremiumKey == "mcxc")
        
        if unl and MCXC.State.IsLocked and MCXC.State.LockedTarget and MCXC.State.LockedTarget.Character and MCXC.State.LockedTarget.Character:FindFirstChild("HumanoidRootPart") and MCXC.State.LockedTarget.Character:FindFirstChild("Humanoid") and MCXC.State.LockedTarget.Character.Humanoid.Health>0 then
            local predPos = TargetEngine.GetPredPos(MCXC.State.LockedTarget); if predPos then local cam = workspace.CurrentCamera; cam.CFrame = cam.CFrame:Lerp(CFrame.lookAt(cam.CFrame.Position, predPos), MCXC.Config.Smoothness); myR.CFrame = myR.CFrame:Lerp(CFrame.lookAt(myR.Position, Vector3.new(predPos.X, myR.Position.Y, predPos.Z)), MCXC.Config.Smoothness + 0.1) end
        else
            if MCXC.State.IsLocked then MCXC.State.IsLocked=false; MCXC.State.LockedTarget=nil; pcall(function() local st = MCXC.Config.StealthMode; Utils.Tween(getgenv().BtnAim, {BackgroundTransparency=st and 1 or 0.3}, 0.1); Utils.Tween(getgenv().StrAim, {Color=Color3.fromRGB(255,80,255), Thickness=st and 0.5 or 1.5}, 0.1) end) end
        end

        if MCXC.Config.Macro then for _,v in ipairs(LP.Character:GetChildren()) do if v:IsA("BoolValue") and v.Value==true and (string.find(string.lower(v.Name),"stun") or string.find(string.lower(v.Name),"cant") or string.find(string.lower(v.Name),"nodash")) then v.Value=false end end end
        
        local isMv = LP.Character:FindFirstChild("Humanoid") and LP.Character.Humanoid.MoveDirection.Magnitude > 0
        if unl and MCXC.Config.FakeLag and isMv and not MCXC.State.IsCombo then
            MCXC.State.LagTick = MCXC.State.LagTick + 1
            if MCXC.State.LagTick >= MCXC.Config.FakeLagTick then MCXC.State.GhostCF = myR.CFrame; myR.CFrame = MCXC.State.GhostCF * CFrame.new(math.random(-150,150), 0, math.random(-150,150)); MCXC.State.LagTick = 0 end
        else MCXC.State.LagTick = 0 end
        
        if now - MCXC.State.LastTick >= 0.1 then
            MCXC.State.LastTick = now; local cam = workspace.CurrentCamera; local cF2, cR2 = Vector2.new(cam.CFrame.LookVector.X, cam.CFrame.LookVector.Z).Unit, Vector2.new(cam.CFrame.RightVector.X, cam.CFrame.RightVector.Z).Unit
            if MCXC.Config.ShowMap then MapFrame.Visible = true else MapFrame.Visible = false end
            
            local tracerTarget = nil; local tracerMinD = 500; local closestEnemy = nil; local minD = math.huge
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                    local d = (p.Character.HumanoidRootPart.Position - myR.Position).Magnitude
                    if d < tracerMinD and d <= MCXC.Config.LockRange then tracerMinD = d; tracerTarget = p end
                    if d < minD and d <= MCXC.Config.RenderDist then minD = d; closestEnemy = p end
                end
            end
            
            if MCXC.Config.ViewTracer and tracerTarget then
                if not MCXC.Cache.TracerLine then local a1 = Instance.new("Attachment"); local a2 = Instance.new("Attachment"); local b = Instance.new("Beam"); b.Attachment0 = a1; b.Attachment1 = a2; b.FaceCamera = true; b.Width0 = 0.6; b.Width1 = 0.6; b.Transparency = NumberSequence.new(0.1); b.Color = ColorSequence.new(Theme.Accent); MCXC.Cache.TracerLine = {Beam = b, A1 = a1, A2 = a2} end
                local tR = tracerTarget.Character.HumanoidRootPart; local trObj = MCXC.Cache.TracerLine; trObj.A1.Parent = myR; trObj.A2.Parent = tR; trObj.Beam.Parent = tR; trObj.Beam.Enabled = true
            else if MCXC.Cache.TracerLine then MCXC.Cache.TracerLine.Beam.Enabled = false end end
            
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                    local tR = p.Character.HumanoidRootPart; local dist = (tR.Position - myR.Position).Magnitude; local isTarg = (p == MCXC.State.LockedTarget); local isClose = (p == closestEnemy)
                    if unl and MCXC.Config.Hitbox then tR.Size = Vector3.new(MCXC.Config.HitboxSize, MCXC.Config.HitboxSize, MCXC.Config.HitboxSize); tR.Transparency = 0.8; tR.CanCollide = false else if tR.Size.X > 5 then tR.Size = Vector3.new(2,2,1); tR.Transparency = 1 end end
                    
                    if MCXC.Config.ShowMap then
                        if dist <= MCXC.Config.MapRange then
                            local of2 = Vector2.new(tR.Position.X - myR.Position.X, tR.Position.Z - myR.Position.Z); local sc = (MCXC.Config.MapSize / 2) / MCXC.Config.MapRange; local uX, uY = of2:Dot(cR2) * sc, -of2:Dot(cF2) * sc
                            if not MCXC.Cache.MapDots[p.Name] then local d = Instance.new("Frame", DotsContainer); d.Size = UDim2.new(0,6,0,6); Instance.new("UICorner",d).CornerRadius = UDim.new(1,0); d.ZIndex = 4; MCXC.Cache.MapDots[p.Name] = d end
                            local dot = MCXC.Cache.MapDots[p.Name]; dot.BackgroundColor3 = isTarg and Theme.Accent or Theme.Danger; dot.Position = UDim2.new(0.5, uX-3, 0.5, uY-3); dot.Visible = true
                        elseif MCXC.Cache.MapDots[p.Name] then MCXC.Cache.MapDots[p.Name].Visible = false end
                    else if MCXC.Cache.MapDots[p.Name] then MCXC.Cache.MapDots[p.Name].Visible = false end end
                    
                    if MCXC.Config.ESP and dist <= MCXC.Config.RenderDist then
                        if not MCXC.Cache.ESP[p.Name] or MCXC.Cache.ESP[p.Name].Parent ~= tR then
                            if MCXC.Cache.ESP[p.Name] then MCXC.Cache.ESP[p.Name]:Destroy() end
                            local bg = Instance.new("BillboardGui", tR); bg.Size = UDim2.new(0,200,0,50); bg.AlwaysOnTop = true; bg.StudsOffset = Vector3.new(0,3,0); local txt = Instance.new("TextLabel", bg); txt.Size = UDim2.new(1,0,1,0); txt.BackgroundTransparency = 1; txt.Font = Enum.Font.GothamBold; txt.TextSize = 11; txt.TextStrokeTransparency = 0.5; MCXC.Cache.ESP[p.Name] = bg
                        end
                        local hp, mhp = 0, 0; pcall(function() hp = math.floor(p.Character.Humanoid.Health); mhp = math.floor(p.Character.Humanoid.MaxHealth) end); local w = p.Character:FindFirstChildOfClass("Tool"); w = w and w.Name or "None"
                        local gui = MCXC.Cache.ESP[p.Name]; gui.Adornee = tR; gui.TextLabel.Text = string.format("%s\nHP: %d/%d | W: %s\nDist: %dm", p.Name, hp, mhp, string.sub(w,1,15), math.floor(dist))
                        gui.TextLabel.TextColor3 = (hp>0 and hp<=300) and Theme.Danger or (isClose and Theme.Accent or Theme.Text); gui.Enabled = true
                    elseif MCXC.Cache.ESP[p.Name] then MCXC.Cache.ESP[p.Name].Enabled = false end
                else
                    if MCXC.Cache.MapDots[p.Name] then MCXC.Cache.MapDots[p.Name].Visible = false end; if MCXC.Cache.ESP[p.Name] then MCXC.Cache.ESP[p.Name].Enabled = false end
                end
            end
        end
    end)
end)
