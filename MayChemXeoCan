local function GetToolType(tool) if not tool then return "0" end; local n, v = string.lower(tool.Name), ""; local tt = tool:FindFirstChild("ToolTip"); if tt then v = string.lower(tostring(tt.Value)) end; for i=1,4 do for _,k in ipairs(tArr[i]) do if string.find(n,k) or string.find(v,k) then return tostring(i) end end end; return "0" end

function Combat.ExecuteCombo(comboStr, btnRef, stroke, baseColor)
    if MCXC.State.IsCombo then return end
    MCXC.State.IsCombo = true; MCXC.State.CancelCombo = false
    Utils.Tween(btnRef, {BackgroundTransparency=0.1}, 0.05); Utils.Tween(stroke, {Thickness=2.5, Color=Color3.fromRGB(255,255,255)}, 0.05)
    task.spawn(function()
        task.wait(0.01)
        local seq = string.upper(comboStr); local first = string.sub(seq,1,1); local cT = LP.Character:FindFirstChildOfClass("Tool")
        local curWepType = "0"; local currentHeldKey = nil
        if cT then curWepType = GetToolType(cT) end
        if (first=="1" or first=="2" or first=="3" or first=="4") and cT and GetToolType(cT)==first then seq=string.sub(seq,2) end
        
        for i = 1, #seq do
            if MCXC.State.CancelCombo or Combat.IsStunned(LP.Character) then MCXC.State.CancelCombo = true; break end
            local key = string.sub(seq, i, i)
            if string.match(key, "[1-4]") then
                curWepType = key
                local tT = LP.Character:FindFirstChildOfClass("Tool")
                if not tT or GetToolType(tT)~=key then
                    local kc = Enum.KeyCode.One; if key=="2" then kc=Enum.KeyCode.Two elseif key=="3" then kc=Enum.KeyCode.Three elseif key=="4" then kc=Enum.KeyCode.Four end
                    VIM:SendKeyEvent(true, kc, false, game); if not Combat.SW(0.01) then break end; VIM:SendKeyEvent(false, kc, false, game)
                    local w=tick(); while tick()-w<0.3 do if MCXC.State.CancelCombo or Combat.IsStunned(LP.Character) then MCXC.State.CancelCombo = true; break end; local tk=LP.Character:FindFirstChildOfClass("Tool"); if tk and GetToolType(tk)==key then break end; task.wait() end
                    if MCXC.State.CancelCombo then break end
                    local finalTk = LP.Character:FindFirstChildOfClass("Tool")
                    if not finalTk or GetToolType(finalTk)~=key then MCXC.State.CancelCombo = true; break end
                    if not Combat.SW(0.01) then break end
                end
            elseif string.match(key, "[ZXCVF]") then
                local kc = Enum.KeyCode[key]; local holdKey = "Hold_"..curWepType..key
                local holdTime = MCXC.Config.HoldEnabled and (MCXC.Config[holdKey] or 0) or 0
                currentHeldKey = kc
                VIM:SendKeyEvent(true, kc, false, game)
                if holdTime > 0 then if not Combat.SW(holdTime) then break end else if not Combat.SW(0.01) then break end end
                VIM:SendKeyEvent(false, kc, false, game)
                currentHeldKey = nil
                local wR = tick(); local trg = false
                while tick()-wR < 0.4 do if MCXC.State.CancelCombo or Combat.IsStunned(LP.Character) then MCXC.State.CancelCombo = true; break end; if Combat.IsBusy(LP.Character) then trg=true; break end; task.wait() end
                if trg and not MCXC.State.CancelCombo then local wA=tick(); while Combat.IsBusy(LP.Character) and tick()-wA < 3.0 do if MCXC.State.CancelCombo or Combat.IsStunned(LP.Character) then MCXC.State.CancelCombo = true; break end; task.wait() end end
                if not Combat.SW(0.01) then break end
            end
        end
        if currentHeldKey then pcall(function() VIM:SendKeyEvent(false, currentHeldKey, false, game) end) end
        MCXC.State.IsCombo = false; MCXC.State.CancelCombo = false
        Utils.Tween(btnRef, {BackgroundTransparency=MCXC.Config.UITrans}, 0.15); Utils.Tween(stroke, {Thickness=1.5, Color=baseColor}, 0.15)
    end)
end

