getgenv().ExecBtnAim.InputBegan:Connect(function(inp)
    if (inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseButton1) and not getgenv().SetupMode then
        getgenv().IsLocked = not getgenv().IsLocked
        if getgenv().IsLocked then
            local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if myRoot then
                local near, mD = nil, math.huge
                for _,p in ipairs(Players:GetPlayers()) do if p~=LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health>0 then local d=(p.Character.HumanoidRootPart.Position-myRoot.Position).Magnitude; if d<mD then mD=d; near=p end end end
