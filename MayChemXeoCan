local Utils = {}
function Utils.Tween(obj, props, time) local tw = TweenService:Create(obj, TweenInfo.new(time or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props); tw:Play(); return tw end
function Utils.GetPing() pcall(function() MCXC.State.Ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000 end); return math.clamp(MCXC.State.Ping, 0.02, 0.3) end
function Utils.MakeDraggable(topbar, object)
    local dragging, dragInput, dragStart, startPos
    topbar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; dragStart = input.Position; startPos = object.Position; input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end) end end)
    topbar.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
    UserInputService.InputChanged:Connect(function(input) if input == dragInput and dragging then local delta = input.Position - dragStart; object.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)
end

local Combat = {}
function Combat.IsBusy(char)
    if not char then return false end
    for _, v in ipairs(char:GetChildren()) do 
        if v:IsA("BoolValue") and v.Value then 
            local n = string.lower(v.Name)
            if string.find(n, "busy") or string.find(n, "using") or string.find(n, "cast") then return true end 
        end 
    end
    return false
end

local tArr = {{"melee","human","art","claw","step","talon"},{"fruit","dragon","kitsune","dough","leopard","buddha","portal"},{"sword","katana","blade","sword","tushita","yama","cdk","trident"},{"gun","rifle","kabucha","serpent","guitar"}}
local function GetToolType(tool) if not tool then return "0" end; local n, v = string.lower(tool.Name), ""; local tt = tool:FindFirstChild("ToolTip"); if tt then v = string.lower(tostring(tt.Value)) end; for i=1,4 do for _,k in ipairs(tArr[i]) do if string.find(n,k) or string.find(v,k) then return tostring(i) end end end; return "0" end

function Combat.ExecuteCombo(comboStr, btnRef, stroke, baseColor)
    if MCXC.State.IsCombo then return end
    MCXC.State.IsCombo = true; Utils.Tween(btnRef, {BackgroundTransparency=0.1}, 0.1); Utils.Tween(stroke, {Thickness=2.5, Color=Color3.fromRGB(255,255,255)}, 0.1)
    
    task.spawn(function()
        task.wait(0.01); local seq = string.upper(comboStr); local first = string.sub(seq,1,1); local cT = LP.Character:FindFirstChildOfClass("Tool")
        if (first=="1" or first=="2" or first=="3" or first=="4") and cT and GetToolType(cT)==first then seq=string.sub(seq,2) end
        
        local currentWep = "0"
        for i = 1, #seq do
            if MCXC.State.CancelCombo then break end
            local key = string.sub(seq, i, i)
            if string.match(key, "[1-4]") then
                currentWep = key
                local tT = LP.Character:FindFirstChildOfClass("Tool"); if not tT or GetToolType(tT)~=key then
                    local kc = Enum.KeyCode.One; if key=="2" then kc=Enum.KeyCode.Two elseif key=="3" then kc=Enum.KeyCode.Three elseif key=="4" then kc=Enum.KeyCode.Four end
                    VIM:SendKeyEvent(true, kc, false, game); task.wait(0.02); VIM:SendKeyEvent(false, kc, false, game); local w=tick(); while tick()-w<0.3 do if MCXC.State.CancelCombo then break end; local tk=LP.Character:FindFirstChildOfClass("Tool"); if tk and GetToolType(tk)==key then break end; task.wait() end; task.wait(0.05)
                end
            elseif string.match(key, "[ZXCVF]") then
                local isHold = false
                if MCXC.Config.HoldSkills and MCXC.Config.HoldSkills ~= "" then
                    if string.find(string.upper(MCXC.Config.HoldSkills), currentWep .. key) then
                        isHold = true
                    end
                end
                
                local kc = Enum.KeyCode[key]
                VIM:SendKeyEvent(true, kc, false, game)
                if isHold then
                    local hTime = MCXC.Config["HoldTime"..key] or 0.5
                    task.wait(hTime)
                else
                    task.wait(0.05)
                end
                VIM:SendKeyEvent(false, kc, false, game)
                
                local wR = tick(); local trg = false
                while tick()-wR < 0.4 do if MCXC.State.CancelCombo then break end; if Combat.IsBusy(LP.Character) then trg=true; break end; task.wait() end
                if trg then 
                    local wA=tick()
                    while Combat.IsBusy(LP.Character) and tick()-wA < 1.5 do if MCXC.State.CancelCombo then break end; task.wait() end; 
                    task.wait(MCXC.Config.ActionDelay) 
                else 
                    task.wait(MCXC.Config.BaseDelay) 
                end
            end
        end
        MCXC.State.IsCombo = false; MCXC.State.CancelCombo = false
        Utils.Tween(btnRef, {BackgroundTransparency=MCXC.Config.UITrans}, 0.2); Utils.Tween(stroke, {Thickness=1.5, Color=baseColor}, 0.2)
    end)
end

