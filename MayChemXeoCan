        shadow.Size, shadow.Position, shadow.BackgroundTransparency, shadow.Image, shadow.ImageColor3, shadow.ImageTransparency, shadow.ZIndex = U2(1,6,1,6), U2(0,-3,0,-3), 1, "rbxassetid://6015897843", C3(0,0,0), 0.4, 24
