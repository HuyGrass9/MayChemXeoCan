local function MayChemXeoCan_IsHolding(char)
    if not char then return false end
    local tags = {"Charging", "Holding", "UsingSkill", "Stance", "Active", "Channeling", "Power", "Action"}
    for _, tag in ipairs(tags) do
        if char:FindFirstChild(tag) then return true end
    end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then
        for _, tag in ipairs(tags) do
            if tool:FindFirstChild(tag) then return true end
        end
    end
    return false
end

local function SmartEquip(slot)
    if not LP.Character then return false end
    
    local targetTooltip = ""
    if slot == "1" then targetTooltip = "melee"
    elseif slot == "2" then targetTooltip = "blox fruit"
    elseif slot == "3" then targetTooltip = "sword"
    elseif slot == "4" then targetTooltip = "gun"
    else return false end

    local currentTool = LP.Character:FindFirstChildOfClass("Tool")
    if currentTool and currentTool:FindFirstChild("ToolTip") and string.find(string.lower(currentTool.ToolTip.Value), targetTooltip) then
        return false 
    end

    for _, tool in pairs(LP.Backpack:GetChildren()) do
        if tool:IsA("Tool") and tool:FindFirstChild("ToolTip") and string.find(string.lower(tool.ToolTip.Value), targetTooltip) then
            if currentTool then currentTool.Parent = LP.Backpack end
            task.wait(0.01)
            tool.Parent = LP.Character
            return true 
        end
    end
    return false
end

local isComboing = false
ExecBtn.MouseButton1Click:Connect(function()
    if isComboing then return end
    isComboing = true
    ExecStroke.Color = Color3.fromRGB(0, 255, 100)
    
    task.spawn(function()
        local str = string.upper(Config.ComboStr)
        local cDelay = tonumber(Config.ComboDelay) or 0.05
        
        for i = 1, #str do
            local char = string.sub(str, i, i)
            local key = nil
            
            if char == "1" or char == "2" or char == "3" or char == "4" then
                local switched = SmartEquip(char)
                if switched then task.wait(0.05) end
            elseif char == "Z" then key = Enum.KeyCode.Z
            elseif char == "X" then key = Enum.KeyCode.X
            elseif char == "C" then key = Enum.KeyCode.C
            elseif char == "V" then key = Enum.KeyCode.V
            elseif char == "F" then key = Enum.KeyCode.F
            end
            
            if key then
                VIM:SendKeyEvent(true, key, false, game)
                task.wait(0.02)
                VIM:SendKeyEvent(false, key, false, game)
                
                task.wait(cDelay)
                
                local holdTimeout = tick()
                while MayChemXeoCan_IsHolding(LP.Character) and (tick() - holdTimeout) < 2.0 do
                    RunService.Heartbeat:Wait()
                end
            end
        end
        isComboing = false
        ExecStroke.Color = Color3.fromRGB(255, 50, 50)
    end)
end)

local function MayChemXeoCan_ApexPvP(char)
    char.ChildAdded:Connect(function(v)
        if v:IsA("Tool") and string.find(string.lower(v.Name), "katana") then
            UI.Enabled = true
        end
        if v:IsA("BoolValue") or v:IsA("StringValue") then
            local name = string.lower(v.Name)
            if string.find(name, "busy") or string.find(name, "cant") or string.find(name, "nodash") or string.find(name, "nojump") then
                task.spawn(function()
                    local mDelay = tonumber(Config.MacroDelay) or 0.04
                    task.wait(mDelay)
                    while char and char.Parent and MayChemXeoCan_IsHolding(char) do
                        RunService.Heartbeat:Wait()
                    end
                    if v and v.Parent and v:IsA("BoolValue") then
                        v.Value = false
                    end
                end)
            end
        end
    end)
end

if LP.Character then MayChemXeoCan_ApexPvP(LP.Character) end
LP.CharacterAdded:Connect(MayChemXeoCan_ApexPvP)

RunService.RenderStepped:Connect(function()
    if LP.Character then
        local hum = LP.Character:FindFirstChild("Humanoid")
        if hum and hum.WalkSpeed < 35 then
            local isStunned = false
            for _, tag in pairs(LP.Character:GetChildren()) do
                if tag:IsA("BoolValue") and string.find(string.lower(tag.Name), "stun") and tag.Value == true then
                    isStunned = true; break
                end
            end
            if not isStunned and not MayChemXeoCan_IsHolding(LP.Character) then
                hum.WalkSpeed = 35
            end
        end
    end
end)

