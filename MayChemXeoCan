local function GetToolType(tool)
    local tt = tool:FindFirstChild("ToolTip")
    if not tt then return "0" end
    local v = string.lower(tostring(tt.Value))
    if string.find(v, "melee") or string.find(v, "cận chiến") or string.find(v, "võ thuật") then return "1" end
    if string.find(v, "fruit") or string.find(v, "trái") or string.find(v, "ác quỷ") then return "2" end
    if string.find(v, "sword") or string.find(v, "kiếm") or string.find(v, "đao") then return "3" end
    if string.find(v, "gun") or string.find(v, "súng") or string.find(v, "pháo") then return "4" end
    return "0"
end

local function GetWeaponData()
    local melee, fruit, sword = "None", "None", "None"
    if not LP.Character then return melee, fruit, sword end
    local items = {}
    if LP.Backpack then for _, v in ipairs(LP.Backpack:GetChildren()) do if v:IsA("Tool") then table.insert(items, v) end end end
    for _, v in ipairs(LP.Character:GetChildren()) do if v:IsA("Tool") then table.insert(items, v) end end
    
    for _, tool in ipairs(items) do
        local typ = GetToolType(tool)
        if typ == "1" then melee = tool.Name
        elseif typ == "2" then fruit = tool.Name
        elseif typ == "3" then sword = tool.Name end
    end
    return melee, fruit, sword
end

local function ForceEquipPhysical(slotStr)
    if not LP.Character or not LP.Character:FindFirstChild("Humanoid") then return end
    
    local current = LP.Character:FindFirstChildOfClass("Tool")
    if current and GetToolType(current) == slotStr then return end

    local tools = {}
    if LP.Backpack then for _, v in ipairs(LP.Backpack:GetChildren()) do if v:IsA("Tool") then table.insert(tools, v) end end end
    for _, v in ipairs(LP.Character:GetChildren()) do if v:IsA("Tool") then table.insert(tools, v) end end

    local targetTool = nil
    for _, tool in ipairs(tools) do
        if GetToolType(tool) == slotStr then
            targetTool = tool
            break
        end
    end

    if targetTool then
        LP.Character.Humanoid:EquipTool(targetTool)
        local timeout = tick()
        while targetTool.Parent ~= LP.Character and tick() - timeout < 0.4 do RunService.Heartbeat:Wait() end
        task.wait(0.05)
    end
end

local function IsBusy(char)
    if not char then return false end
    local badTags = {"busy", "cant", "stun", "nodash", "nojump", "usingskill"}
    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("BoolValue") and v.Value == true then
            local n = string.lower(v.Name)
            for _, tag in ipairs(badTags) do
                if string.find(n, tag) then return true end
            end
        end
    end
    return false
end

local function ForceClearStun(char)
    if not char then return end
    local badTags = {"busy", "cant", "stun", "nodash", "nojump", "usingskill"}
    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("BoolValue") and v.Value == true then
            local n = string.lower(v.Name)
            for _, tag in ipairs(badTags) do
                if string.find(n, tag) then v.Value = false end
            end
        end
    end
end

local function FireAICombo(str, stroke, baseColor)
    stroke.Color = Color3.fromRGB(255, 255, 255)
    task.spawn(function()
        local s = string.upper(str)
        local kDelay = tonumber(Config.ComboDelay) or 0.05
        
        for i = 1, #s do
            local char = string.sub(s, i, i)
            if char == "1" or char == "2" or char == "3" or char == "4" then
                ForceEquipPhysical(char)
            elseif char == "Z" or char == "X" or char == "C" or char == "V" or char == "F" then
                ForceClearStun(LP.Character)
                local kc = Enum.KeyCode[char]
                
                VIM:SendKeyEvent(true, kc, false, game)
                task.wait(0.01)
                VIM:SendKeyEvent(false, kc, false, game)
                
                local waitReg = tick()
                local triggered = false
                while tick() - waitReg < 0.15 do
                    if IsBusy(LP.Character) then triggered = true; break end
                    RunService.Heartbeat:Wait()
                end
                
                if triggered then
                    local waitAnim = tick()
                    while IsBusy(LP.Character) and tick() - waitAnim < 1.0 do
                        RunService.Heartbeat:Wait()
                    end
                end
                
                task.wait(kDelay)
                ForceClearStun(LP.Character)
            end
        end
        stroke.Color = baseColor
    end)
end

