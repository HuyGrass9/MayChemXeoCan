local function SnipeGoldenForce()
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Model") or v:IsA("BasePart") then
            local name = string.lower(v.Name)
            if string.find(name, "golden") and string.find(name, "egg") then
                local targetPart = v:IsA("Model") and (v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Part") or v.PrimaryPart) or v
                local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                if hrp and targetPart and targetPart.Parent then
                    local dist = (hrp.Position - targetPart.Position).Magnitude
                    local tInfo = TweenInfo.new(dist / 400, Enum.EasingStyle.Linear)
                    local tw = TweenService:Create(hrp, tInfo, {CFrame = targetPart.CFrame})
                    tw:Play()
                    local timeout = 0
                    while getgenv().MayChemXeoCan_Auto and targetPart and targetPart.Parent and timeout < 25 do
                        local currentHrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                        if not currentHrp then break end
                        if (currentHrp.Position - targetPart.Position).Magnitude < 10 then break end
                        task.wait(0.1)
                        timeout = timeout + 1
                    end
                    if tw then tw:Cancel() end
                end
            end
        end
    end
end

local function HitAndRunShip()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        if currentTween then currentTween:Cancel() end
        getgenv().IsTweening = false
        
        local plat = Instance.new("Part")
        plat.Size = Vector3.new(300, 2, 300)
        plat.CFrame = CFrame.new(ShipTarget - Vector3.new(0, 6, 0))
        plat.Anchored = true
        plat.Transparency = 1
        plat.Parent = Workspace
        
        hrp.CFrame = CFrame.new(ShipTarget)
        task.wait(0.5)
        
        local timer = 0
        while timer < 4 and getgenv().MayChemXeoCan_Auto do
            SnipeGoldenForce()
            task.wait(0.5)
            timer = timer + 0.5
        end
        
        plat:Destroy()
        
        if getgenv().MayChemXeoCan_Auto then
            local returnHrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if returnHrp then
                returnHrp.CFrame = CFrame.new(SafeReturn)
                task.wait(1.5)
            end
        end
    end
end

local function BypassTween(targetPos)
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local dist = (hrp.Position - targetPos).Magnitude
    if dist < 30 then return end
    
    getgenv().IsTweening = true
    
    local bv = hrp:FindFirstChild("MayChemBV")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "MayChemBV"
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = hrp
    end
    
    local tInfo = TweenInfo.new(dist / 350, Enum.EasingStyle.Linear)
    currentTween = TweenService:Create(hrp, tInfo, {CFrame = CFrame.new(targetPos)})
    currentTween:Play()
    
    while getgenv().IsTweening and getgenv().MayChemXeoCan_Auto do
        local currentHrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not currentHrp then break end
        if (currentHrp.Position - targetPos).Magnitude < 40 then break end
        task.wait(0.1)
    end
    
    if currentTween then currentTween:Cancel() end
    if bv then bv:Destroy() end
    getgenv().IsTweening = false
end

local function GetClosestPoint(currentPos, pointList)
    local closest = nil
    local minDist = math.huge
    local bestIndex = -1
    for i, pos in ipairs(pointList) do
        local dist = (currentPos - pos).Magnitude
        if dist < minDist then
            minDist = dist
            closest = pos
            bestIndex = i
        end
    end
    return closest, bestIndex
end

