local function SnipeGoldenForce()
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Model") or v:IsA("BasePart") then
            local name = string.lower(v.Name)
            if string.find(name, "golden") and string.find(name, "egg") then
                local targetPart = v:IsA("Model") and (v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Part") or v.PrimaryPart) or v
                local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                if hrp and targetPart then
                    local dist = (hrp.Position - targetPart.Position).Magnitude
                    local tInfo = TweenInfo.new(dist / 350, Enum.EasingStyle.Linear)
                    local tween = TweenService:Create(hrp, tInfo, {CFrame = targetPart.CFrame})
                    tween:Play()
                    tween.Completed:Wait()
                    task.wait(0.3)
                end
            end
        end
    end
end

local function BypassTween(targetPos)
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local dist = (hrp.Position - targetPos).Magnitude
    if dist < 30 then return end
    getgenv().IsTweening = true
    local tInfo = TweenInfo.new(dist / 330, Enum.EasingStyle.Linear)
    currentTween = TweenService:Create(hrp, tInfo, {CFrame = CFrame.new(targetPos)})
    currentTween:Play()
    currentTween.Completed:Wait()
    getgenv().IsTweening = false
end

RunService.Stepped:Connect(function()
    if getgenv().IsTweening and LP.Character then
        for _, v in pairs(LP.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
        local hrp = LP.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        end
    end
end)

Btn.MouseButton1Click:Connect(function()
    getgenv().AutoEggUltra = not getgenv().AutoEggUltra
    if getgenv().AutoEggUltra then
        Btn.Text = "ULTRA GOLDEN: ON"
        Btn.TextColor3 = Color3.fromRGB(255, 215, 0)
    else
        Btn.Text = "ULTRA GOLDEN: OFF"
        Btn.TextColor3 = Color3.fromRGB(255, 80, 80)
        if currentTween then currentTween:Cancel() end
        getgenv().IsTweening = false
    end
end)

task.spawn(function()
    while true do
        if getgenv().AutoEggUltra then
            for _, pos in ipairs(Sea2UltimatePoints) do
                if not getgenv().AutoEggUltra then break end
                if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                    BypassTween(pos + Vector3.new(0, 55, 0))
                    SnipeGoldenForce()
                    task.wait(2)
                end
            end
        end
        task.wait(1)
    end
end)
