-- CAMERA LOCK BINDING (PRIORITY 205 - VƯỢT QUYỀN CAMERA ROBLOX)
RunService:BindToRenderStep("MacroAimLock", 205, function()
    if getgenv().IsLocked and getgenv().LockedTarget and getgenv().LockedTarget.Character and getgenv().LockedTarget.Character:FindFirstChild("HumanoidRootPart") and getgenv().LockedTarget.Character:FindFirstChild("Humanoid") and getgenv().LockedTarget.Character.Humanoid.Health>0 then
        local cam, eP = workspace.CurrentCamera, getgenv().LockedTarget.Character.HumanoidRootPart.Position
        local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        cam.CFrame = CFrame.lookAt(cam.CFrame.Position, eP)
        if myR then myR.CFrame = CFrame.lookAt(myR.Position, Vector3.new(eP.X, myR.Position.Y, eP.Z)) end
    elseif getgenv().IsLocked then
        getgenv().IsLocked = false; getgenv().LockedTarget = nil
        pcall(function() TweenService:Create(getgenv().StrokeAim, TweenInfo.new(0.2), {Color=Color3.fromRGB(255,80,255), Thickness=1.5, Transparency=0.2}):Play(); TweenService:Create(getgenv().ExecBtnAim, TweenInfo.new(0.2), {BackgroundTransparency=0.3}):Play() end)
    end
end)

