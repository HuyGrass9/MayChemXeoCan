    dragCover.Font = Enum.Font.GothamBold
    dragCover.TextSize = 10
    dragCover.Visible = false
    dragCover.Draggable = true
    Instance.new("UICorner", dragCover).CornerRadius = UDim.new(1, 0)
    dragCover.Parent = btn

    return btn, stroke, dragCover
end

