getgenv().MCXC_ActiveSlider = nil
local function CreateSlider(parent, yPos, text, min, max, configKey, isInt, btnRef)
    local frame = Instance.new("Frame", parent); frame.Size = UDim2.new(1,0,0,45); frame.Position = UDim2.new(0,0,0,yPos); frame.BackgroundTransparency=1
    local lbl = Instance.new("TextLabel", frame); lbl.Size = UDim2.new(0.9,0,0,20); lbl.Position = UDim2.new(0.05,0,0,0); lbl.BackgroundTransparency=1; lbl.Text = text..": "..tostring(Config[configKey]); lbl.TextColor3=Color3.fromRGB(200,200,200); lbl.Font=Enum.Font.GothamMedium; lbl.TextSize=10; lbl.TextXAlignment=Enum.TextXAlignment.Left
    local bg = Instance.new("Frame", frame); bg.Size = UDim2.new(0.9,0,0,6); bg.Position = UDim2.new(0.05,0,0,25); bg.BackgroundColor3=Color3.fromRGB(35,35,40); Instance.new("UICorner", bg).CornerRadius=UDim.new(1,0)
    local fill = Instance.new("Frame", bg); fill.Size = UDim2.new((Config[configKey]-min)/(max-min),0,1,0); fill.BackgroundColor3=Color3.fromRGB(0,255,150); Instance.new("UICorner", fill).CornerRadius=UDim.new(1,0)
    local touchArea = Instance.new("TextButton", bg); touchArea.Size = UDim2.new(1,0,0,16); touchArea.Position = UDim2.new(0,0,0.5,-8); touchArea.BackgroundTransparency=1; touchArea.Text=""
    local dragging = false
    touchArea.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then if not getgenv().MCXC_ActiveSlider then getgenv().MCXC_ActiveSlider=configKey; dragging=true end end end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then if dragging and getgenv().MCXC_ActiveSlider==configKey then dragging=false; getgenv().MCXC_ActiveSlider=nil; SaveConfig() end end end)
    RunService.RenderStepped:Connect(function()
        if dragging and getgenv().MCXC_ActiveSlider==configKey then
            local pct = math.clamp((UserInputService:GetMouseLocation().X - bg.AbsolutePosition.X)/bg.AbsoluteSize.X, 0, 1)
            local val = min + (max-min)*pct; if isInt then val=math.floor(val) else val=math.floor(val*100)/100 end
            fill.Size = UDim2.new(pct,0,1,0); lbl.Text = text..": "..tostring(val); Config[configKey]=val
            if btnRef then btnRef.Size=UDim2.new(0,val,0,val); btnRef.TextSize=math.clamp(val*0.4,15,45) end
            if configKey=="MapSize" then MapFrame.Size=UDim2.new(0,val,0,val) end
            if configKey=="TouchZoneSize" then TouchZone.Size=UDim2.new(0,val,0,val) end
        end
    end)
end

