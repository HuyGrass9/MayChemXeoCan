local Combat = {}
function Combat.CheckStates(char) if typeof(char) ~= "Instance" or not char:IsA("Model") then return false, false end; local stun, busy = false, false; for _, v in ipairs(char:GetChildren()) do if v.ClassName == "BoolValue" and v.Value == true then local n = s_lower(v.Name); if s_find(n, "stun") or s_find(n, "cant") then stun = true end; if s_find(n, "busy") or s_find(n, "using") or s_find(n, "cast") then busy = true end; if stun and busy then break end end end; return stun, busy end
function Combat.SW(t) local s = t_tick(); local adj = m_max(0.001, t - (MCXC.State.Ping * 0.6)); while t_tick() - s < adj do local st, _ = Combat.CheckStates(LP.Character); if MCXC.State.Status == "IDLE" or st then return false end; RS.Heartbeat:Wait() end; return true end
local tArr = {{"melee","human","art","claw","step","talon"},{"fruit","dragon","kitsune","dough","leopard","buddha","portal"},{"sword","katana","blade","tushita","yama","cdk","trident"},{"gun","rifle","kabucha","serpent","guitar"}}
local function GetToolType(tool) if typeof(tool) ~= "Instance" then return "0" end; local n, v = s_lower(tool.Name), ""; local tt = tool:FindFirstChild("ToolTip"); if tt and typeof(tt.Value) == "string" then v = s_lower(tt.Value) end; for i=1,4 do for _,k in ipairs(tArr[i]) do if s_find(n,k) or s_find(v,k) then return tostring(i) end end end; return "0" end
function Combat.ExecuteCombo(comboId, comboStr, onStart, onFail, onSuccess)
    if MCXC.State.Status == "CASTING" then return end; MCXC.State.Status = "CASTING"; MCXC.State.CurrentCombo = comboId; if onStart then onStart() end
    t_spawn(function()
        Combat.SW(0.005); local seq = s_upper(comboStr); local first = s_sub(seq,1,1); local cT = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
        local curWepType, currentHeldKey, comboFailed = "0", nil, false
        if cT then curWepType = GetToolType(cT) end
        if (first=="1" or first=="2" or first=="3" or first=="4") and cT and GetToolType(cT)==first then seq=s_sub(seq,2) end
        for i = 1, #seq do
            local st, _ = Combat.CheckStates(LP.Character); if MCXC.State.Status == "IDLE" or st then comboFailed = true; break end
            local key = s_sub(seq, i, i)
            if s_match(key, "[1-4]") then
                curWepType = key; local tT = LP.Character:FindFirstChildOfClass("Tool")
                if not tT or GetToolType(tT)~=key then
                    local kc = Enum.KeyCode.One; if key=="2" then kc=Enum.KeyCode.Two elseif key=="3" then kc=Enum.KeyCode.Three elseif key=="4" then kc=Enum.KeyCode.Four end
                    VIM:SendKeyEvent(true, kc, false, game); Combat.SW(0.01); VIM:SendKeyEvent(false, kc, false, game); local w=t_tick(); while t_tick()-w<0.3 do if MCXC.State.Status == "IDLE" then break end; local tk=LP.Character:FindFirstChildOfClass("Tool"); if tk and GetToolType(tk)==key then break end; RS.Heartbeat:Wait() end; if not LP.Character:FindFirstChildOfClass("Tool") or GetToolType(LP.Character:FindFirstChildOfClass("Tool"))~=key then comboFailed=true; break end
                end
            elseif s_match(key, "[ZXCVF]") then
                local kc = Enum.KeyCode[key]; local holdTime = MCXC.Config.HoldEnabled and (MCXC.Config["Hold_"..curWepType..key] or 0) or 0; currentHeldKey = kc; VIM:SendKeyEvent(true, kc, false, game); if not Combat.SW(m_max(0.01, holdTime)) then comboFailed=true; break end; VIM:SendKeyEvent(false, kc, false, game); currentHeldKey = nil; local wR, trg = t_tick(), false; while t_tick()-wR < 0.25 do local stn, bsy = Combat.CheckStates(LP.Character); if MCXC.State.Status == "IDLE" or stn then break end; if bsy then trg=true; break end; RS.Heartbeat:Wait() end; if trg then local wA=t_tick(); while t_tick()-wA < 3.0 do local stn, bsy = Combat.CheckStates(LP.Character); if MCXC.State.Status == "IDLE" or stn or not bsy then break end; RS.Heartbeat:Wait() end end; if MCXC.State.Status == "IDLE" then comboFailed=true; break end; Combat.SW(0.01)
            end
        end
        if currentHeldKey then pcall(function() VIM:SendKeyEvent(false, currentHeldKey, false, game) end) end; MCXC.State.Status = "IDLE"; if comboFailed then if onFail then onFail() end else if onSuccess then onSuccess() end end
    end)
end

