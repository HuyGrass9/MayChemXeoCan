local function ProcessQueue()
    if MCXC.State.Status == "IDLE" and MCXC.State.ComboQueue then
        local q = MCXC.State.ComboQueue; MCXC.State.ComboQueue = nil
        Combat.ExecuteCombo(q.id, q.str, q.strUI, q.col, ProcessQueue)
    end
end

local function HandleCombo(id, str, strUI, col)
    if MCXC.State.SetupMode then return end
    if MCXC.State.Status == "CASTING" then
        if MCXC.State.CurrentCombo == id then
            if MCXC.Config.CancelOnTap then MCXC.State.Status = "IDLE"; MCXC.State.ComboQueue = nil end
        else
            MCXC.State.ComboQueue = {id=id, str=str, strUI=strUI, col=col}
            Utils.Tween(strUI, {Thickness=3, Color=Theme.Target}, 0.15)
        end
    else Combat.ExecuteCombo(id, str, strUI, col, ProcessQueue) end
end

