getgenv().MCXC_ActiveSlider = nil
local function CreateSlider(parent, text, min, max, configKey, isInt, btnRef)
    local frame = Instance.new("Frame", parent); frame.Size = UDim2.new(0.95,0,0,40); frame.BackgroundTransparency=1
    local lbl = Instance.new("TextLabel", frame); lbl.Size = UDim2.new(1,0,0,15); lbl.BackgroundTransparency=1; lbl.Text = text..": "..tostring(Config[configKey]); lbl.TextColor3=Color3.fromRGB(200,200,200); lbl.Font=Enum.Font.GothamMedium; lbl.TextSize=9; lbl.TextXAlignment=Enum.TextXAlignment.Left
    local bg = Instance.new("Frame", frame); bg.Size = UDim2.new(1,0,0,4); bg.Position = UDim2.new(0,0,0,25); bg.BackgroundColor3=Color3.fromRGB(35,35,40); Instance.new("UICorner", bg).CornerRadius=UDim.new(1,0)
    local fill = Instance.new("Frame", bg); fill.Size = UDim2.new((Config[configKey]-min)/(max-min),0,1,0); fill.BackgroundColor3=Color3.fromRGB(0,255,150); Instance.new("UICorner", fill).CornerRadius=UDim.new(1,0)
    local touchArea = Instance.new("TextButton", bg); touchArea.Size = UDim2.new(1,0,0,16); touchArea.Position = UDim2.new(0,0,0.5,-8); touchArea.BackgroundTransparency=1; touchArea.Text=""
    local dragging = false
    touchArea.InputBegan:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseButton1 then if not getgenv().MCXC_ActiveSlider then getgenv().MCXC_ActiveSlider=configKey; dragging=true end end end)
    UserInputService.InputEnded:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseButton1 then if dragging and getgenv().MCXC_ActiveSlider==configKey then dragging=false; getgenv().MCXC_ActiveSlider=nil; SaveConfig() end end end)
    RunService.RenderStepped:Connect(function()
        if dragging and getgenv().MCXC_ActiveSlider==configKey then
            local pct = math.clamp((UserInputService:GetMouseLocation().X - bg.AbsolutePosition.X)/bg.AbsoluteSize.X, 0, 1)
            local val = min + (max-min)*pct; if isInt then val=math.floor(val) else val=math.floor(val*100)/100 end
            fill.Size = UDim2.new(pct,0,1,0); lbl.Text = text..": "..tostring(val); Config[configKey]=val
            if configKey == "BtnSizeC" and getgenv().ExecBtnC then getgenv().ExecBtnC.Size = UDim2.new(0,val,0,val) end; if configKey == "BtnSizeC2" and getgenv().ExecBtnC2 then getgenv().ExecBtnC2.Size = UDim2.new(0,val,0,val) end
            if configKey == "BtnSizeX" and getgenv().ExecBtnX then getgenv().ExecBtnX.Size = UDim2.new(0,val,0,val) end; if configKey == "BtnSizeAim" and getgenv().ExecBtnAim then getgenv().ExecBtnAim.Size = UDim2.new(0,val,0,val) end
            if configKey=="MapSize" then MapFrame.Size=UDim2.new(0,val,0,val) end; if configKey=="TouchZoneSize" then TouchZone.Size=UDim2.new(0,val,0,val) end
        end
    end)
    return frame
end

