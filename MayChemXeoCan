function Reticle.GetTargetInReticle()
    if not MCXC.Config.ReticleEnabled then return CameraLock.GetNearestEnemy() end
    local cam = workspace.CurrentCamera
    if not cam then return nil end
    local center = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
    local bestTarget = nil
    local bestDist = MCXC.Config.ReticleSize
    for _, p in pairs(MCXC.State.ActivePlayers) do
        if p ~= LP and not IsAlly(p) and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local screenPos, onScreen = cam:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if dist <= MCXC.Config.ReticleSize and dist < bestDist then
                        bestDist = dist
                        bestTarget = p
                    end
                end
            end
        end
    end
    return bestTarget
end

local CameraLock = {}
function CameraLock.GetNearestEnemy()
    if MCXC.Config.ReticleEnabled then
        return Reticle.GetTargetInReticle()
    end
    local myChar = LP.Character; if not myChar then return nil end
    local myHrp = myChar:FindFirstChild("HumanoidRootPart"); if not myHrp then return nil end
    local myPos = myHrp.Position
    local nearest, minDist = nil, 1000
    for _, p in pairs(MCXC.State.ActivePlayers) do
        if p ~= LP and not IsAlly(p) and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local dist = (hrp.Position - myPos).Magnitude
                if dist < minDist then minDist = dist; nearest = p end
            end
        end
    end
    return nearest
end
function CameraLock.Enable()
    if MCXC.Config.CameraLockEnabled then
        local target = CameraLock.GetNearestEnemy()
        if target then
            MCXC.State.CameraLockActive = true
            MCXC.State.RestoreCamera = false
        else
            MCXC.State.CameraLockActive = false
            if MCXC.Config.ReticleEnabled then
                MCXC.State.Status = "NO TARGET"
            end
        end
    end
end
function CameraLock.Disable() MCXC.State.CameraLockActive = false; MCXC.State.RestoreCamera = true end
function CameraLock.ForceRestore()
    local cam = workspace.CurrentCamera
    if cam then
        cam.CameraType = Enum.CameraType.Custom
        if LP.Character then
            local hum = LP.Character:FindFirstChild("Humanoid")
            if hum then cam.CameraSubject = hum end
        end
    end
    MCXC.State.TargetCameraCFrame = nil
    MCXC.State.RestoreCamera = false
    MCXC.State.CameraLockActive = false
end
function CameraLock.SmoothRestore()
    local cam = workspace.CurrentCamera; local myChar = LP.Character
    if not myChar or not cam then return end
    local myR = myChar:FindFirstChild("HumanoidRootPart"); if not myR then return end
    MCXC.State.TargetCameraCFrame = CFrame.new(myR.Position) * (myR.CFrame - myR.Position)
end
function CameraLock.Update()
    local cam = workspace.CurrentCamera; if not cam then return end
    if MCXC.State.CameraLockActive then
        local target = CameraLock.GetNearestEnemy()
        if target and target.Character then
            local hrp = target.Character:FindFirstChild("HumanoidRootPart")
            if hrp and LP.Character then
                local myHrp = LP.Character:FindFirstChild("HumanoidRootPart")
                if myHrp then cam.CFrame = CFrame.new(myHrp.Position, hrp.Position) end
            else
                CameraLock.ForceRestore()
            end
        else
            CameraLock.ForceRestore()
        end
    elseif MCXC.State.RestoreCamera then
        if MCXC.State.TargetCameraCFrame then
            cam.CFrame = cam.CFrame:Lerp(MCXC.State.TargetCameraCFrame, 0.3)
            if (cam.CFrame.Position - MCXC.State.TargetCameraCFrame.Position).Magnitude < 0.5 then
                CameraLock.ForceRestore()
            end
        else
            CameraLock.SmoothRestore()
        end
    end
end

local Combat = {}
local STUN_NAMES = {Stun = true, Stunned = true, CantMove = true, Freeze = true, Paralyze = true}
function Combat.IsStunned(char)
    if typeof(char) ~= "Instance" or not char:IsA("Model") then return false end
    for _, v in ipairs(char:GetChildren()) do if v:IsA("BoolValue") and v.Value == true and STUN_NAMES[v.Name] then return true end end
    return false
end
function Combat.WaitForStunEnd(char) while Combat.IsStunned(char) do t_wait() end end
function Combat.CheckBusy(char)
    if typeof(char) ~= "Instance" or not char:IsA("Model") then return false end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("BoolValue") and v.Value == true then
            local n = s_lower(v.Name)
            if s_find(n, "busy") or s_find(n, "using") or s_find(n, "cast") then return true end
        end
    end
    return false
end

local function GetToolType(tool)
    if not tool then return nil end
    if MCXC.Cache.ToolTypes[tool] then return MCXC.Cache.ToolTypes[tool] end
    local n = s_lower(tool.Name); local t = nil
    if s_find(n, "art") or s_find(n, "claw") or s_find(n, "step") or s_find(n, "talon") or s_find(n, "melee") then t = "1"
    elseif s_find(n, "fruit") or s_find(n, "kitsune") or s_find(n, "dough") or s_find(n, "leopard") or s_find(n, "buddha") then t = "2"
    elseif s_find(n, "sword") or s_find(n, "katana") or s_find(n, "blade") or s_find(n, "tushita") or s_find(n, "yama") or s_find(n, "cdk") or s_find(n, "trident") or s_find(n, "lamp") or s_find(n, "heart") or s_find(n, "anchor") then t = "3"
    elseif s_find(n, "gun") or s_find(n, "rifle") or s_find(n, "kabucha") or s_find(n, "serpent") or s_find(n, "guitar") then t = "4"
    end
    if t then MCXC.Cache.ToolTypes[tool] = t end
    return t
end

