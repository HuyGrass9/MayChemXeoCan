local function CreateActionBtn(name, yPos, color, showKey, sizeKey, isToggle)
    local btn = Instance.new("TextButton")
    local sz = Config[sizeKey]
    btn.Size = UDim2.new(0, sz, 0, sz)
    btn.Position = UDim2.new(0.8, 0, yPos, 0)
    btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    btn.BackgroundTransparency = (isToggle and Config.AimEnabled) and 0 or 0.2
    btn.Text = name
    btn.TextColor3 = color
    btn.Font = Enum.Font.GothamBlack
    btn.TextSize = math.clamp(sz * 0.4, 15, 45)
    btn.Visible = Config[showKey]
    btn.Active = true
    btn.Selectable = false
    btn.Draggable = Config.SetupMode
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = (isToggle and Config.AimEnabled) and Color3.fromRGB(255, 255, 255) or color
    stroke.Thickness = (isToggle and Config.AimEnabled) and 3 or 2
    btn.Parent = UI
    return btn, stroke
end

