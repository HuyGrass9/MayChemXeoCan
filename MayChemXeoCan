function Combat.SwitchToTool(key)
    local current = GetCurrentToolType(); if current == key then return true end
    local targetTool = nil
    for _, v in ipairs(LP.Backpack:GetChildren()) do
        if v:IsA("Tool") and GetToolType(v) == key then targetTool = v; break end
    end
    if not targetTool then return false end
    local hum = LP.Character and LP.Character:FindFirstChild("Humanoid")
    if not hum then return false end
    for attempt = 1, 3 do
        pcall(function() hum:EquipTool(targetTool) end)
        local start = t_tick()
        repeat
            if GetCurrentToolType() == key then
                local equippedTool = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
                if equippedTool and equippedTool == targetTool then t_wait(0.1); return true end
            end
            t_wait()
        until t_tick() - start > 1.0
        if attempt == 2 then
            local kc = key == "2" and Enum.KeyCode.Two or key == "3" and Enum.KeyCode.Three or key == "4" and Enum.KeyCode.Four or Enum.KeyCode.One
            VIM:SendKeyEvent(true, kc, false, game); VIM:SendKeyEvent(false, kc, false, game)
        end
    end
    return false
end

function Combat.WaitForSkillActivation(tool, key)
    local activated = false
    local conn = tool.Activated:Connect(function() activated = true end)
    local start = t_tick()
    t_wait(0.08)
    repeat
        if activated then break end
        if LP.Character and Combat.CheckBusy(LP.Character) then activated = true; break end
        if LP.Character and Combat.IsStunned(LP.Character) then break end
