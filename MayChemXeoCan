local Combat = {}
function Combat.CheckStates(char)
    if typeof(char) ~= "Instance" or not char:IsA("Model") then return false, false end
    local stun, busy = false, false
    for _, v in ipairs(char:GetChildren()) do
        if v.ClassName == "BoolValue" and v.Value == true then
            local n = s_lower(v.Name)
            if s_find(n, "stun") or s_find(n, "cant") then stun = true end
            if s_find(n, "busy") or s_find(n, "using") or s_find(n, "cast") then busy = true end
            if stun and busy then break end
        end
    end
    return stun, busy
end
function Combat.CheckStunGrace()
    local st, bs = Combat.CheckStates(LP.Character)
    if st then
        local sT = t_tick()
        while t_tick() - sT < 0.6 do
            st, bs = Combat.CheckStates(LP.Character)
            if not st then return false, bs end
            task.wait()
        end
        return true, bs
    end
    return false, bs
end
function Combat.SmartWait(desiredTime)
    local start = t_tick()
    local adj = m_max(0.005, desiredTime - (MCXC.State.Ping * 0.5))
    while t_tick() - start < adj do
        local st, _ = Combat.CheckStates(LP.Character)
        if s_find(MCXC.State.Status, "CANCEL") or st then return false end
        task.wait()
    end
    return true
end

local function GetToolType(tool)
    local n = s_lower(tool.Name)
    if s_find(n, "art") or s_find(n, "claw") or s_find(n, "step") or s_find(n, "talon") or s_find(n, "melee") then return "1" end
    if s_find(n, "fruit") or s_find(n, "kitsune") or s_find(n, "dough") or s_find(n, "leopard") or s_find(n, "buddha") then return "2" end
    if s_find(n, "sword") or s_find(n, "katana") or s_find(n, "blade") or s_find(n, "tushita") or s_find(n, "yama") or s_find(n, "cdk") or s_find(n, "trident") or s_find(n, "lamp") or s_find(n, "heart") or s_find(n, "anchor") then return "3" end
    if s_find(n, "gun") or s_find(n, "rifle") or s_find(n, "kabucha") or s_find(n, "serpent") or s_find(n, "guitar") then return "4" end
    return nil
end

local function GetCurrentToolType()
    local tool = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
    return tool and GetToolType(tool)
end

local function FastCastManual(kc)
    if not MCXC.Config.Macro or s_find(MCXC.State.Status, "CASTING") then return end
    t_spawn(function()
        local s = t_tick()
        while t_tick() - s < 0.15 do
            local st, bsy = Combat.CheckStates(LP.Character)
            if st or bsy then break end
            VIM:SendKeyEvent(true, kc, false, game)
            task.wait()
        end
        VIM:SendKeyEvent(false, kc, false, game)
    end)
end
UIS.InputBegan:Connect(function(i, p) if not p and s_match(i.KeyCode.Name, "[ZXCVF]") then FastCastManual(i.KeyCode) end end)

function Combat.ExecuteCombo(comboId, comboStr, strUI, col, onEnd)
    if s_find(MCXC.State.Status, "CASTING") and MCXC.State.CurrentCombo ~= comboId then return end
    MCXC.State.CurrentCombo = comboId
    t_spawn(function()
        Utils.Tween(strUI, {Thickness=2.5, Color=Theme.Text}, 0.05)
        local seq = s_upper(comboStr)
        local comboFailed, failR = false, ""
        for i = 1, #seq do
            local st, _ = Combat.CheckStunGrace()
            if st or s_find(MCXC.State.Status, "CANCEL") then comboFailed = true; failR = "STUNNED"; break end
            local key = s_sub(seq, i, i)
            if s_match(key, "[1-4]") then
                local currentType = GetCurrentToolType()
                if currentType ~= key then
                    MCXC.State.Status = "CASTING " .. comboId .. ": EQUIP " .. key
                    local targetTool = nil
                    for _, v in ipairs(LP.Backpack:GetChildren()) do
                        if v:IsA("Tool") and GetToolType(v) == key then targetTool = v break end
                    end
                    if targetTool then
                        local equipSuccess = false
                        local conn; conn = LP.Character.ChildAdded:Connect(function(child)
                            if child == targetTool then equipSuccess = true end
                        end)
                        pcall(function() LP.Character.Humanoid:EquipTool(targetTool) end)
                        local start = t_tick()
                        while not equipSuccess and t_tick() - start < 1.0 do task.wait() end
                        conn:Disconnect()
                        if not equipSuccess then comboFailed = true; failR = "EQUIP TIMEOUT"; break end
                    else
                        local kc = Enum.KeyCode.One
                        if key=="2" then kc=Enum.KeyCode.Two elseif key=="3" then kc=Enum.KeyCode.Three elseif key=="4" then kc=Enum.KeyCode.Four end
                        VIM:SendKeyEvent(true, kc, false, game)
                        Combat.SmartWait(0.03)
                        VIM:SendKeyEvent(false, kc, false, game)
                        Combat.SmartWait(0.1)
                    end
                end
            elseif s_match(key, "[ZXCVF]") then
                MCXC.State.Status = "CASTING " .. comboId .. ": [" .. key .. "]"
                local kc = Enum.KeyCode[key]
                local currentType = GetCurrentToolType()
                local holdTime = 0
                if MCXC.Config.HoldEnabled and currentType then
                    holdTime = MCXC.Config.Hold_["Hold_"..currentType..key] or 0
                end
                local fired = false
                local wR = t_tick()
                while t_tick() - wR < 0.25 do
                    local stn, bsy2 = Combat.CheckStunGrace()
                    if stn then comboFailed = true; failR = "STUNNED"; break end
                    if bsy2 then fired = true; break end
                    VIM:SendKeyEvent(true, kc, false, game)
                    task.wait()
                end
                if comboFailed then break end
                if fired and holdTime > 0 then
                    local hS = t_tick()
                    while t_tick() - hS < holdTime do
                        if Combat.CheckStunGrace() then break end
                        task.wait()
                    end
                end
                VIM:SendKeyEvent(false, kc, false, game)
                if not fired then comboFailed = true; failR = "COOLDOWN"; break end
                local wA = t_tick()
                while t_tick() - wA < 1.2 do
                    local stn, bsy2 = Combat.CheckStunGrace()
                    if stn or not bsy2 then if stn then comboFailed=true; failR="INTERRUPTED" end; break end
                    task.wait()
                end
                if comboFailed then break end
            end
        end
        if comboFailed then
            MCXC.State.Status = "CANCEL: " .. failR; MCXC.State.ComboQueue = nil
            Utils.Tween(strUI, {Thickness=2.5, Color=Theme.Danger}, 0.1)
            t_delay(0.5, function() Utils.Tween(strUI, {Thickness=1.5, Color=col}, 0.2) end)
        else
            MCXC.State.Status = "DONE: " .. comboId; Utils.Tween(strUI, {Thickness=1.5, Color=col}, 0.2)
        end
        t_delay(0.2, function()
            if not s_find(MCXC.State.Status, "CASTING") and not MCXC.State.ComboQueue then
                MCXC.State.Status = "IDLE"
            end
            if onEnd then onEnd() end
        end)
    end)
end

