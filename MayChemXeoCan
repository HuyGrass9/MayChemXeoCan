            local c = I_new("Frame", frm); c.Size = U2(1, 0, 0, 38); c.BackgroundColor3 = Theme.ElementBG; c.LayoutOrder = self.LIdx
            I_new("UICorner", c).CornerRadius = UD(0, 8)
            local l = I_new("TextLabel", c); l.Size = U2(1, -60, 1, 0); l.Position = U2(0, 10, 0, 0)
            l.BackgroundTransparency = 1; l.Text = text; l.TextColor3 = Config[key] and Theme.Text or Theme.TextDark; l.Font = Theme.Font; l.TextSize = 12
            local swBG = I_new("Frame", c); swBG.Size = U2(0, 34, 0, 18); swBG.Position = U2(1, -44, 0.5, -9)
            swBG.BackgroundColor3 = Config[key] and Theme.Accent or C3(50, 50, 55)
            I_new("UICorner", swBG).CornerRadius = UD(1, 0)
            local swDot = I_new("Frame", swBG); swDot.Size = U2(0, 14, 0, 14)
            swDot.Position = Config[key] and U2(1, -17, 0.5, -7) or U2(0, 3, 0.5, -7); swDot.BackgroundColor3 = Theme.Text
            I_new("UICorner", swDot).CornerRadius = UD(1, 0)
            local b = I_new("TextButton", c); b.Size = U2(1, 0, 1, 0); b.BackgroundTransparency = 1; b.Text = ""
            b.MouseButton1Click:Connect(function()
                Config[key] = not Config[key]
                l.TextColor3 = Config[key] and Theme.Text or Theme.TextDark
                swBG.BackgroundColor3 = Config[key] and Theme.Accent or C3(50, 50, 55)
                swDot.Position = Config[key] and U2(1, -17, 0.5, -7) or U2(0, 3, 0.5, -7)
                if callback then callback(Config[key]) end
            end)
            return c
        end
        function TabObj:CreateSlider(text, min, max, default, key, callback)
            self.LIdx = self.LIdx + 1; Config[key] = default
            local c = I_new("Frame", frm); c.Size = U2(1, 0, 0, 50); c.BackgroundColor3 = Theme.ElementBG; c.LayoutOrder = self.LIdx
            I_new("UICorner", c).CornerRadius = UD(0, 8)
            local l = I_new("TextLabel", c); l.Size = U2(1, -20, 0, 20); l.Position = U2(0, 10, 0, 4)
            l.BackgroundTransparency = 1; l.Text = text .. ": " .. default; l.TextColor3 = Theme.TextDark; l.Font = Theme.Font; l.TextSize = 12
            local vL = I_new("TextLabel", c); vL.Size = U2(0.3, 0, 0, 20); vL.Position = U2(0.7, -10, 0, 4)
            vL.BackgroundTransparency = 1; vL.TextColor3 = Theme.Accent; vL.Font = Theme.FontBold; vL.TextSize = 12; vL.ZIndex = 5; vL.Text = tostring(default)
            local tr = I_new("Frame", c); tr.Size = U2(1, -20, 0, 6); tr.Position = U2(0, 10, 0, 30); tr.BackgroundColor3 = C3(40, 40, 45)
            I_new("UICorner", tr).CornerRadius = UD(1, 0)
            local fill = I_new("Frame", tr); fill.Size = U2((default - min) / (max - min), 0, 1, 0); fill.BackgroundColor3 = Theme.Accent
            I_new("UICorner", fill).CornerRadius = UD(1, 0)
            local tB = I_new("TextButton", c); tB.Size = U2(1, 0, 1, 0); tB.BackgroundTransparency = 1; tB.Text = ""
            local drag = false
            local function upd(i)
                local p = m_clamp((i.Position.X - tr.AbsolutePosition.X) / tr.AbsoluteSize.X, 0, 1)
                local newVal = min + (max - min) * p
                if newVal ~= newVal then return end
                newVal = m_floor(newVal); Config[key] = newVal; fill.Size = U2(p, 0, 1, 0); vL.Text = tostring(newVal); l.Text = text .. ": " .. newVal
                if callback then callback(newVal) end
            end
            tB.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true; upd(i) end end)
            Services.UserInputService.InputEnded:Connect(function() drag = false end)
            Services.UserInputService.InputChanged:Connect(function(i) if drag and (i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseMovement) then upd(i) end end)
            return c
        end
        return TabObj
    end
    return Window, gui
end

