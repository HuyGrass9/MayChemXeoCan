function MCXC.Combat.CheckStates(char)
    if not char then return false, false end
    local stun, busy = false, false
    for _, v in ipairs(char:GetChildren()) do if v.ClassName == "BoolValue" and v.Value == true then local n = s_lower(v.Name); if s_find(n, "stun") or s_find(n, "cant") then stun = true end; if s_find(n, "busy") or s_find(n, "using") or s_find(n, "cast") then busy = true end end end; return stun, busy
end

function MCXC.Combat.SW(t)
    local s = t_tick(); local adj = m_max(0.001, t - (MCXC.State.Ping * 0.5))
    while t_tick() - s < adj do 
        local st, _ = MCXC.Combat.CheckStates(LP.Character); if MCXC.State.Status == "IDLE" or st then return false end
        RS.Heartbeat:Wait() 
    end; return true
end

