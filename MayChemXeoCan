                    getgenv().LockedTarget = near
                    TweenService:Create(getgenv().StrokeAim, TweenInfo.new(0.2), {Color=Color3.fromRGB(255,255,255), Thickness=3, Transparency=0}):Play()
                    TweenService:Create(getgenv().ExecBtnAim, TweenInfo.new(0.2), {BackgroundTransparency=0.1}):Play()
                else getgenv().IsLocked = false end
            else getgenv().IsLocked = false end
        else
            getgenv().LockedTarget = nil
            pcall(function() TweenService:Create(getgenv().StrokeAim, TweenInfo.new(0.2), {Color=Color3.fromRGB(255,80,255), Thickness=1.5, Transparency=0.2}):Play(); TweenService:Create(getgenv().ExecBtnAim, TweenInfo.new(0.2), {BackgroundTransparency=0.3}):Play() end)
        end
    end
end)

