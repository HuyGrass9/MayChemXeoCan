local function UltraFastWait(sec)
    local start = tick()
    while tick() - start < sec do RunService.Heartbeat:Wait() end
end

local function GetActiveWeapon()
    if not LP.Character then return nil end
    local tool = LP.Character:FindFirstChildOfClass("Tool")
    if tool and tool:FindFirstChild("ToolTip") then
        local tt = string.lower(tool.ToolTip.Value)
        if string.find(tt, "melee") then return "1" end
        if string.find(tt, "fruit") then return "2" end
        if string.find(tt, "sword") then return "3" end
        if string.find(tt, "gun") then return "4" end
    end
    return nil
end

local function ForceEquip(slot)
    if not LP.Character or not LP.Character:FindFirstChild("Humanoid") then return end
    local tMap = {["1"]="melee", ["2"]="fruit", ["3"]="sword", ["4"]="gun"}
    local target = tMap[slot]
    if not target then return end

    local current = LP.Character:FindFirstChildOfClass("Tool")
    if current and current:FindFirstChild("ToolTip") and string.find(string.lower(current.ToolTip.Value), target) then return end

    for _, tool in ipairs(LP.Backpack:GetChildren()) do
        if tool:IsA("Tool") and tool:FindFirstChild("ToolTip") and string.find(string.lower(tool.ToolTip.Value), target) then
            LP.Character.Humanoid:EquipTool(tool)
            local timeout = tick()
            while not LP.Character:FindFirstChild(tool.Name) and tick() - timeout < 0.5 do RunService.Heartbeat:Wait() end
            UltraFastWait(0.1)
            return
        end
    end
end

local function CoreExecute(comboStr, stroke, colorOff)
    stroke.Color = Color3.fromRGB(255, 255, 255)
    task.spawn(function()
        local str = string.upper(comboStr)
        local cDelay = tonumber(Config.ComboDelay) or 0.01
        
        for i = 1, #str do
            local char = string.sub(str, i, i)
            if char == "1" or char == "2" or char == "3" or char == "4" then
                if GetActiveWeapon() ~= char then ForceEquip(char) end
            elseif char == "Z" or char == "X" or char == "C" or char == "V" or char == "F" then
                local kCode = Enum.KeyCode[char]
                VIM:SendKeyEvent(true, kCode, false, game)
                UltraFastWait(0.001)
                VIM:SendKeyEvent(false, kCode, false, game)
                UltraFastWait(cDelay)
            end
        end
        stroke.Color = colorOff
    end)
end

