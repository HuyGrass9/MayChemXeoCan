local function CreateActionBtn(name, xPos, yPos, color, showKey, sizeKey)
    local btn = Instance.new("TextButton")
    local sz = Config[sizeKey]
    btn.Size = UDim2.new(0, sz, 0, sz)
    btn.Position = UDim2.new(xPos, 0, yPos, 0)
    btn.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    btn.BackgroundTransparency = 0.1
    btn.Text = name
    btn.TextColor3 = color
    btn.Font = Enum.Font.GothamBlack
    btn.TextSize = math.clamp(sz * 0.4, 15, 45)
    btn.Visible = Config[showKey]
    btn.Active = true
    btn.Selectable = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)
