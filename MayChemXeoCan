local function CreateTab(name, xPos, isActive)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.5, 0, 1, 0)
    btn.Position = UDim2.new(xPos, 0, 0, 0)
    btn.BackgroundColor3 = isActive and Color3.fromRGB(255, 20, 20) or Color3.fromRGB(20, 20, 25)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.BorderSizePixel = 0
    btn.Parent = TabBar
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, -65)
    frame.Position = UDim2.new(0, 0, 0, 65)
    frame.BackgroundTransparency = 1
    frame.Visible = isActive
    frame.Parent = Menu
    
    TabBtns[name] = btn
    TabFrames[name] = frame
    
    btn.MouseButton1Click:Connect(function()
        for k, v in pairs(TabFrames) do v.Visible = (k == name) end
        for k, v in pairs(TabBtns) do v.BackgroundColor3 = (k == name) and Color3.fromRGB(255, 20, 20) or Color3.fromRGB(20, 20, 25) end
    end)
    return frame
end

