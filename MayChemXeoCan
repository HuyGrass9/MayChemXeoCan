local SettingsList = {}
local function CreateSlider(parent, text, min, max, key, isInt)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(0.95,0,0,40); f.BackgroundTransparency = 1; f.Visible = false; table.insert(SettingsList, f)
    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1,0,0,15); l.BackgroundTransparency = 1; l.Text = text..": "..tostring(Titan.Config[key]); l.TextColor3 = Color3.fromRGB(200,200,200); l.Font = Enum.Font.GothamMedium; l.TextSize = 10; l.TextXAlignment = Enum.TextXAlignment.Left
    local bg = Instance.new("Frame", f); bg.Size = UDim2.new(1,0,0,6); bg.Position = UDim2.new(0,0,0,22); bg.BackgroundColor3 = Color3.fromRGB(35,35,40); Instance.new("UICorner", bg).CornerRadius = UDim.new(1,0)
    local fill = Instance.new("Frame", bg); fill.Size = UDim2.new((Titan.Config[key]-min)/(max-min),0,1,0); fill.BackgroundColor3 = Color3.fromRGB(0,255,150); Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
    local tArea = Instance.new("TextButton", f); tArea.Size = UDim2.new(1,0,1,0); tArea.BackgroundTransparency = 1; tArea.Text = ""
    local drag = false
    
    local function update(inp)
        local pct = math.clamp((inp.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        local val = min + (max-min)*pct; if isInt then val = math.floor(val) else val = math.floor(val*100)/100 end
        fill.Size = UDim2.new(pct,0,1,0); l.Text = text..": "..tostring(val); Titan.Config[key] = val
        if key=="BtnSizeC" and getgenv().BtnC then getgenv().BtnC.Size=UDim2.new(0,val,0,val) end; if key=="BtnSizeC2" and getgenv().BtnC2 then getgenv().BtnC2.Size=UDim2.new(0,val,0,val) end
        if key=="BtnSizeX" and getgenv().BtnX then getgenv().BtnX.Size=UDim2.new(0,val,0,val) end; if key=="BtnSizeAim" and getgenv().BtnAim then getgenv().BtnAim.Size=UDim2.new(0,val,0,val) end
        if key=="MapSize" then MapFrame.Size=UDim2.new(0,val,0,val) end
    end
    
    tArea.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true; update(i) end end)
    UserInputService.InputChanged:Connect(function(i) if drag and (i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseMovement) then update(i) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then if drag then drag=false; SaveConfig() end end end)
    return f
end

