local tArr = {{"melee","human","art","claw","step","talon"},{"fruit","dragon","kitsune","dough","leopard","buddha","portal"},{"sword","katana","blade","sword","tushita","yama","cdk","trident"},{"gun","rifle","kabucha","serpent","guitar"}}
local function GetToolType(tool) if not tool then return "0" end; local n, v = string.lower(tool.Name), ""; local tt = tool:FindFirstChild("ToolTip"); if tt then v = string.lower(tostring(tt.Value)) end; for i=1,4 do for _,k in ipairs(tArr[i]) do if string.find(n,k) or string.find(v,k) then return tostring(i) end end end; return "0" end
local function IsBusy(char) if not char then return false end; for _, v in ipairs(char:GetChildren()) do if v:IsA("BoolValue") and v.Value==true and (string.find(string.lower(v.Name), "busy") or string.find(string.lower(v.Name), "using") or string.find(string.lower(v.Name), "cast")) then return true end end; return false end

local function ExCombo(comboStr, btnRef, stroke, baseColor)
    TweenService:Create(btnRef, TweenInfo.new(0.2), {BackgroundTransparency=0.1}):Play(); TweenService:Create(stroke, TweenInfo.new(0.2), {Color=Color3.fromRGB(255,255,255), Thickness=2.5, Transparency=0}):Play()
    if Config.AutoHideC and btnRef.Visible then btnRef.Visible=false; task.delay(Config.HideTimer, function() if not getgenv().MacroHidden and ((btnRef==getgenv().ExecBtnC and Config.ShowC) or (btnRef==getgenv().ExecBtnC2 and Config.ShowC2)) then btnRef.Visible=true end end) end
    task.spawn(function()
        task.wait(0.01); local s = string.upper(comboStr); local first = string.sub(s,1,1); local cT = LP.Character:FindFirstChildOfClass("Tool")
        if (first=="1" or first=="2" or first=="3" or first=="4") and cT and GetToolType(cT)==first then s=string.sub(s,2) end
        for i=1, #s do
            if getgenv().CancelCombo then break end; local char = string.sub(s,i,i)
            if char=="1" or char=="2" or char=="3" or char=="4" then
                local tT = LP.Character:FindFirstChildOfClass("Tool"); if not tT or GetToolType(tT)~=char then
                    local kc = Enum.KeyCode.One; if char=="2" then kc=Enum.KeyCode.Two elseif char=="3" then kc=Enum.KeyCode.Three elseif char=="4" then kc=Enum.KeyCode.Four end
                    VIM:SendKeyEvent(true, kc, false, game); task.wait(0.02); VIM:SendKeyEvent(false, kc, false, game); local w=tick(); while tick()-w<0.3 do if getgenv().CancelCombo then break end; local tk=LP.Character:FindFirstChildOfClass("Tool"); if tk and GetToolType(tk)==char then break end; RunService.Heartbeat:Wait() end; task.wait(0.05)
                end
            elseif char=="Z" or char=="X" or char=="C" or char=="V" or char=="F" then
                local kc = Enum.KeyCode[char]; VIM:SendKeyEvent(true, kc, false, game); task.wait(0.05); VIM:SendKeyEvent(false, kc, false, game); local wR=tick(); local trg=false; while tick()-wR<0.4 do if getgenv().CancelCombo then break end; if IsBusy(LP.Character) then trg=true; break end; RunService.Heartbeat:Wait() end
                if trg then local wA=tick(); while IsBusy(LP.Character) and tick()-wA<3.0 do if getgenv().CancelCombo then break end; RunService.Heartbeat:Wait() end; task.wait(tonumber(Config.ActionDelay) or 0.1) else task.wait(tonumber(Config.ComboDelay) or 0.05) end
            end
        end
        TweenService:Create(btnRef, TweenInfo.new(0.2), {BackgroundTransparency=0.3}):Play(); TweenService:Create(stroke, TweenInfo.new(0.2), {Color=baseColor, Thickness=1.5, Transparency=0.2}):Play()
        if btnRef==getgenv().ExecBtnC2 then getgenv().lockC2=false else getgenv().lockC=false end; getgenv().CancelCombo=false
    end)
end

