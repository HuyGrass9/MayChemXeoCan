local function ObliterateStun(char)
    local badTags = {"busy", "cant", "stun", "nodash", "nojump", "usingskill", "stance", "active", "power"}
    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("BoolValue") or v:IsA("StringValue") then
            local n = string.lower(v.Name)
            for _, tag in ipairs(badTags) do
                if string.find(n, tag) then
                    if v:IsA("BoolValue") and v.Value == true then
                        v.Value = false
                    end
                end
            end
        end
    end
end

RunService.Heartbeat:Connect(function()
    if LP.Character then
        local hum = LP.Character:FindFirstChild("Humanoid")
        if hum and hum.WalkSpeed < 35 then hum.WalkSpeed = 35 end
        
        ObliterateStun(LP.Character)
        
        if Config.Hitbox then
            local s = tonumber(Config.HitboxSize) or 15
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = plr.Character.HumanoidRootPart
                    hrp.Size = Vector3.new(s, s, s)
                    hrp.Transparency = 1
                    hrp.CanCollide = false
                    hrp.Massless = true
                end
            end
        end
    end
end)

