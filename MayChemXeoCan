RunService.Heartbeat:Connect(function()
    pcall(function()
        local now = tick(); local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not myR then return end
        
        if Titan.State.IsLocked and Titan.State.LockedTarget and Titan.State.LockedTarget.Character and Titan.State.LockedTarget.Character:FindFirstChild("HumanoidRootPart") and Titan.State.LockedTarget.Character:FindFirstChild("Humanoid") and Titan.State.LockedTarget.Character.Humanoid.Health>0 then
            local tR = Titan.State.LockedTarget.Character.HumanoidRootPart
            local vel = tR.Velocity; local predPos = tR.Position + (vel * Titan.Config.Prediction)
            local cam = workspace.CurrentCamera; cam.CFrame = cam.CFrame:Lerp(CFrame.lookAt(cam.CFrame.Position, predPos), Titan.Config.Smoothness)
            myR.CFrame = myR.CFrame:Lerp(CFrame.lookAt(myR.Position, Vector3.new(predPos.X, myR.Position.Y, predPos.Z)), Titan.Config.Smoothness + 0.1)
        else
            if Titan.State.IsLocked then Titan.State.IsLocked=false; Titan.State.LockedTarget=nil; Utils.Tween(getgenv().BtnAim, {BackgroundTransparency=0.3}, 0.1); Utils.Tween(getgenv().StrAim, {Color=Color3.fromRGB(255,80,255), Thickness=1.5}, 0.1) end
        end

        if Titan.Config.Macro then for _,v in ipairs(LP.Character:GetChildren()) do if v:IsA("BoolValue") and v.Value==true and (string.find(string.lower(v.Name),"stun") or string.find(string.lower(v.Name),"cant") or string.find(string.lower(v.Name),"nodash")) then v.Value=false end end end
        
        local isMv = LP.Character:FindFirstChild("Humanoid") and LP.Character.Humanoid.MoveDirection.Magnitude > 0
