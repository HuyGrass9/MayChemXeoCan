local ToolManager = {}
local FRUIT_KEYWORDS = {"fruit","kitsune","dough","leopard","buddha","rubber","quake","dark","light","magma","ice","sand","flame","string","barrier","revive","door","love","gravity","paw","phoenix","portal","rumble","shadow","spirit","venom","control","dragon","soul","chop","spin","bomb","smoke","spike","spring","kilo","sound"}
function ToolManager.GetToolType(tool)
    if not tool then return nil end
    if MCXC.Cache.ToolTypes[tool] then return MCXC.Cache.ToolTypes[tool] end
    local n = s_lower(tool.Name); local t = nil
    if s_find(n, "art") or s_find(n, "claw") or s_find(n, "step") or s_find(n, "talon") or s_find(n, "melee") then t = "1"
    elseif s_find(n, "sword") or s_find(n, "katana") or s_find(n, "blade") or s_find(n, "tushita") or s_find(n, "yama") or s_find(n, "cdk") or s_find(n, "trident") or s_find(n, "lamp") or s_find(n, "heart") or s_find(n, "anchor") then t = "3"
    elseif s_find(n, "gun") or s_find(n, "rifle") or s_find(n, "kabucha") or s_find(n, "serpent") or s_find(n, "guitar") then t = "4"
    else
        for _, kw in ipairs(FRUIT_KEYWORDS) do if s_find(n, kw) then t = "2" break end end
    end
    if not t then t = "2" end
    MCXC.Cache.ToolTypes[tool] = t
    return t
end
function ToolManager.GetCurrentToolType()
    local char = LP.Character; if not char then return nil end
    local tool = char:FindFirstChildOfClass("Tool")
    return ToolManager.GetToolType(tool)
end
function ToolManager.SwitchToTool(key)
    if ToolManager.GetCurrentToolType() == key then return true end
    local targetTool = nil
    for _, v in ipairs(LP.Backpack:GetChildren()) do if v:IsA("Tool") and ToolManager.GetToolType(v) == key then targetTool = v; break end end
    if not targetTool then return false end
    local hum = LP.Character and LP.Character:FindFirstChild("Humanoid")
    if hum then pcall(function() hum:EquipTool(targetTool) end) end
    local start = t_now()
    repeat
        if ToolManager.GetCurrentToolType() == key then t_wait(0.05); return true end
        t_wait()
    until t_now() - start > 1.0
    for retry = 1, 3 do
        InputAdapter.EquipToolBySlot(tonumber(key))
        start = t_now()
        repeat
            if ToolManager.GetCurrentToolType() == key then t_wait(0.05); return true end
            t_wait()
        until t_now() - start > 1.0
    end
    return false
end

local CameraLock = {}
function CameraLock.GetNearestEnemy()
    local myChar = LP.Character; if not myChar then return nil end
    local myHrp = myChar:FindFirstChild("HumanoidRootPart"); if not myHrp then return nil end
    local myPos = myHrp.Position
    local nearest, minDist = nil, 1000
    for _, p in pairs(MCXC.State.ActivePlayers) do
        if p ~= LP and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local dist = (hrp.Position - myPos).Magnitude
                if dist < minDist then minDist = dist; nearest = p end
            end
        end
    end
    return nearest
end
function CameraLock.Enable() if MCXC.Config.CameraLockEnabled and CameraLock.GetNearestEnemy() then MCXC.State.CameraLockActive = true end end
function CameraLock.Disable() MCXC.State.CameraLockActive = false; MCXC.State.RestoreCamera = true end
function CameraLock.ForceRestore()
    local cam = workspace.CurrentCamera
    if cam then cam.CameraType = Enum.CameraType.Custom; cam.CameraSubject = LP.Character and LP.Character:FindFirstChild("Humanoid") end
    MCXC.State.CameraLockActive = false; MCXC.State.RestoreCamera = false
end
function CameraLock.Update()
    local cam = workspace.CurrentCamera; if not cam then return end
    if MCXC.State.CameraLockActive then
        local target = CameraLock.GetNearestEnemy()
        if target and target.Character then
            local hrp = target.Character:FindFirstChild("HumanoidRootPart")
            local myHrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if hrp and myHrp then
                local camPos = cam.CFrame.Position
                local targetPos = hrp.Position
                local direction = (targetPos - camPos).Unit
                local distance = (camPos - myHrp.Position).Magnitude
                cam.CFrame = CFrame.new(myHrp.Position - direction * distance, targetPos)
            else CameraLock.ForceRestore() end
        else CameraLock.ForceRestore() end
    elseif MCXC.State.RestoreCamera then CameraLock.ForceRestore() end
end

local Combat = {}
local STUN_NAMES = {Stun=true, Stunned=true, CantMove=true, Freeze=true, Paralyze=true}
function Combat.IsStunned(char)
    if typeof(char) ~= "Instance" or not char:IsA("Model") then return false end
    for _, v in ipairs(char:GetChildren()) do if v:IsA("BoolValue") and v.Value and STUN_NAMES[v.Name] then return true end end
    return false
end
function Combat.CheckBusy(char)
    if typeof(char) ~= "Instance" or not char:IsA("Model") then return false end
    for _, v in ipairs(char:GetChildren()) do if v:IsA("BoolValue") and v.Value then local n = s_lower(v.Name); if s_find(n,"busy") or s_find(n,"using") or s_find(n,"cast") then return true end end end
    return false
end

local function ExecuteStep(comboId, sequence, uiElement, onFinish)
    if not MCXC.State.CurrentCombo then return end
    local steps = s_upper(sequence); local index = 1
    local function nextStep()
        if index > #steps then CameraLock.Disable(); onFinish(true); return end
        if MCXC.State.ComboCancelRequested then CameraLock.ForceRestore(); onFinish(false, "CANCELLED"); return end
        if LP.Character and Combat.IsStunned(LP.Character) then t_wait(0.1); nextStep(); return end
        local key = s_sub(steps, index, index); index = index + 1
        if s_match(key, "[1-4]") then
            if not ToolManager.SwitchToTool(key) then onFinish(false, "TOOL SWITCH FAIL"); return end
            t_wait(0.05)
            nextStep()
        elseif s_match(key, "[ZXCVF]") then
            local tool = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
            if not tool then onFinish(false, "NO TOOL"); return end
            InputAdapter.ActivateTool(tool)
            local start = t_now()
            repeat t_wait() until tool.Activated or (LP.Character and Combat.CheckBusy(LP.Character)) or t_now() - start > 0.5
            while LP.Character and Combat.CheckBusy(LP.Character) do t_wait() end
            t_wait(0.02)
            nextStep()
        else nextStep() end
    end
    nextStep()
end

function Combat.ExecuteCombo(comboId, comboStr, strUI, col, onEnd)
    if not HasCombatAccess() or MCXC.State.CurrentCombo then return end
    MCXC.State.CurrentCombo = comboId; MCXC.State.ComboCancelRequested = false
    CameraLock.Enable()
    Utils.Tween(strUI, {Thickness = 2.5, Color = Theme.Text}, 0.05)
    t_spawn(function()
        ExecuteStep(comboId, comboStr, strUI, function(success, reason)
            if not success then MCXC.State.Status = "FAIL: " .. reason; Utils.Tween(strUI, {Thickness = 2.5, Color = Theme.Danger}, 0.1); t_delay(0.3, function() Utils.Tween(strUI, {Thickness = 1.5, Color = col}, 0.2) end)
            else MCXC.State.Status = "DONE: " .. comboId; Utils.Tween(strUI, {Thickness = 1.5, Color = col}, 0.2) end
            MCXC.State.CurrentCombo = nil
            if onEnd then onEnd() end
            if MCXC.State.ComboQueue then ProcessQueue() end
        end)
    end)
end

