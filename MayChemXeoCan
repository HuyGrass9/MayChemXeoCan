function Utils.ApplySkeletonFix(v)
    if not v or not v:IsDescendantOf(workspace) then return end
    if v:IsDescendantOf(LP.Character) or v:IsA("Tool") then return end
    pcall(function()
        if v:IsA("ParticleEmitter") then
            if v.Rate > 15 then v.Enabled = false end
        elseif v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
            v.Reflectance = 0
        elseif v:IsA("Decal") or v:IsA("Texture") then
            if not s_find(s_lower(v.Parent.Name), "floor") and not s_find(s_lower(v.Parent.Name), "base") then v.Transparency = 1 end
        end
    end)
end

local Combat = {}
function Combat.CheckStates(char)
    if not char or not char:IsA("Model") then return false, false end
    local stun, busy = false, false
    for _, v in ipairs(char:GetChildren()) do 
        if v.ClassName == "BoolValue" and v.Value == true then 
            local n = s_lower(v.Name)
            if s_find(n, "stun") or s_find(n, "cant") then stun = true end
            if s_find(n, "busy") or s_find(n, "using") or s_find(n, "cast") then busy = true end
        end 
    end
    return stun, busy
end

function Combat.SW(t)
    local s = t_tick(); local adj = m_max(0.001, t - (MCXC.State.Ping * 0.5))
    while t_tick() - s < adj do 
        local st, _ = Combat.CheckStates(LP.Character); if MCXC.State.Status == "IDLE" or st then return false end
        RS.Heartbeat:Wait() 
    end; return true
end

local tArr = {{"melee","human","art","claw","step","talon"},{"fruit","dragon","kitsune","dough","leopard","buddha","portal"},{"sword","katana","blade","sword","tushita","yama","cdk","trident"},{"gun","rifle","kabucha","serpent","guitar"}}
local function GetToolType(tool) if not tool or not tool:IsA("Tool") then return "0" end local n, v = s_lower(tool.Name), ""; local tt = tool:FindFirstChild("ToolTip") if tt and typeof(tt.Value) == "string" then v = s_lower(tt.Value) end for i=1,4 do for _,k in ipairs(tArr[i]) do if s_find(n,k) or s_find(v,k) then return tostring(i) end end end return "0" end

function Combat.ExecuteCombo(comboId, comboStr, strUI, col, onEnd)
    if MCXC.State.Status == "CASTING" then return end
    MCXC.State.Status = "CASTING"; MCXC.State.CurrentCombo = comboId
    Utils.Tween(strUI, {Thickness=3, Color=Theme.Text}, 0.1)
    
    t_spawn(function()
        local seq = s_upper(comboStr); local comboFailed = false
        local cT = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
        if s_match(s_sub(seq, 1, 1), "[1-4]") and cT and GetToolType(cT) == s_sub(seq, 1, 1) then seq = s_sub(seq, 2) end
        
        for i = 1, #seq do
            local stun, _ = Combat.CheckStates(LP.Character); if MCXC.State.Status == "IDLE" or stun then comboFailed = true; break end
            local key = s_sub(seq, i, i)
            
            if s_match(key, "[1-4]") then
                local kc = Enum.KeyCode["Number"..key]
                VIM:SendKeyEvent(true, kc, false, game); RS.Heartbeat:Wait(); VIM:SendKeyEvent(false, kc, false, game)
                local w = t_tick(); while t_tick()-w < 0.4 do if MCXC.State.Status == "IDLE" then break end local tk = LP.Character:FindFirstChildOfClass("Tool") if tk and GetToolType(tk)==key then break end RS.Heartbeat:Wait() end
            elseif s_match(key, "[ZXCVF]") then
                local kc = Enum.KeyCode[key]; VIM:SendKeyEvent(true, kc, false, game)
                local hold = MCXC.Config.HoldEnabled and (MCXC.Config["Hold_"..key] or 0) or 0
                if not Combat.SW(m_max(0.01, hold)) then comboFailed = true; break end
                VIM:SendKeyEvent(false, kc, false, game)
                
                local wR, fired = t_tick(), false
                while t_tick()-wR < 0.35 do local s, b = Combat.CheckStates(LP.Character); if s then break end if b then fired = true; break end RS.Heartbeat:Wait() end
                if not fired then comboFailed = true; break end
                
                local wA = t_tick(); while t_tick()-wA < 3.0 do local s, b = Combat.CheckStates(LP.Character); if MCXC.State.Status == "IDLE" or s or not b then break end RS.Heartbeat:Wait() end
                if MCXC.State.Status == "IDLE" then comboFailed = true; break end
            end
        end
        
        MCXC.State.Status = "IDLE"
        if comboFailed then
            MCXC.State.ComboQueue = nil
            Utils.Tween(strUI, {Thickness=3, Color=Theme.Danger}, 0.1)
            t_delay(0.5, function() if MCXC.State.Status == "IDLE" then Utils.Tween(strUI, {Thickness=1.5, Color=col}, 0.2) end end)
        else
            Utils.Tween(strUI, {Thickness=1.5, Color=col}, 0.2)
        end
        if onEnd then onEnd() end
    end)
end
