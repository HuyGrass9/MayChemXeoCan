local Utils = {}
function Utils.GetPing()
    pcall(function() Titan.State.Ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000 end)
    return math.clamp(Titan.State.Ping, 0.02, 0.3)
end
function Utils.HumanDelay(base) return base + Utils.GetPing() + (math.random(10, 30) / 1000) end
function Utils.Tween(obj, props, time) local tw = TweenService:Create(obj, TweenInfo.new(time or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props); tw:Play(); return tw end

local TargetEngine = {}
function TargetEngine.GetValidEnemy()
    local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not myR then return nil end
    local bestTarg, minD = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local dist = (p.Character.HumanoidRootPart.Position - myR.Position).Magnitude
            if dist < Titan.Config.RenderDist and dist < minD then minD = dist; bestTarg = p end
        end
    end
    return bestTarg
end

function TargetEngine.ApplyPrediction(target)
    if not target or not target.Character then return end
    local tR = target.Character:FindFirstChild("HumanoidRootPart")
    local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not tR or not myR then return end
    local vel = tR.Velocity
    local sway = Vector3.new(math.sin(tick()*5)*0.5, math.cos(tick()*3)*0.2, math.sin(tick()*4)*0.5)
    local predPos = tR.Position + (vel * (Utils.GetPing() + Titan.Config.Prediction)) + sway
    local cam = workspace.CurrentCamera
    cam.CFrame = cam.CFrame:Lerp(CFrame.lookAt(cam.CFrame.Position, predPos), Titan.Config.Smoothness)
    myR.CFrame = myR.CFrame:Lerp(CFrame.lookAt(myR.Position, Vector3.new(predPos.X, myR.Position.Y, predPos.Z)), Titan.Config.Smoothness + 0.1)
end

local Combat = {}
function Combat.IsBusy(char)
    if not char then return false end
    for _, v in ipairs(char:GetChildren()) do if v:IsA("BoolValue") and v.Value and string.match(string.lower(v.Name), "busy|using|cast") then return true end end
    return false
end

function Combat.ExecuteCombo(comboStr, btnRef, stroke)
    if Titan.State.IsCombo then return end
    Titan.State.IsCombo = true; Utils.Tween(btnRef, {BackgroundTransparency=0.1}, 0.2); Utils.Tween(stroke, {Thickness=2.5, Color=Color3.fromRGB(255,255,255)}, 0.2)
    task.spawn(function()
        task.wait(Utils.HumanDelay(0.01)); local seq = string.upper(comboStr)
        for i = 1, #seq do
            if not Titan.State.IsCombo then break end
            local key = string.sub(seq, i, i)
            if Titan.Config.AutoAim then TargetEngine.ApplyPrediction(Titan.State.Target) end
            if string.match(key, "[1-4]") then
                local kc = Enum.KeyCode.One; if key=="2" then kc=Enum.KeyCode.Two elseif key=="3" then kc=Enum.KeyCode.Three elseif key=="4" then kc=Enum.KeyCode.Four end
                VIM:SendKeyEvent(true, kc, false, game); task.wait(Utils.HumanDelay(0.02)); VIM:SendKeyEvent(false, kc, false, game)
                task.wait(Utils.HumanDelay(0.1))
            elseif string.match(key, "[ZXCVF]") then
                local kc = Enum.KeyCode[key]; VIM:SendKeyEvent(true, kc, false, game); task.wait(Utils.HumanDelay(0.04)); VIM:SendKeyEvent(false, kc, false, game)
                local wR = tick(); local trg = false
                while tick()-wR < 0.4 do if not Titan.State.IsCombo then break end; if Combat.IsBusy(LP.Character) then trg=true; break end; task.wait() end
                if trg then local wA=tick(); while Combat.IsBusy(LP.Character) and tick()-wA < 3 do if not Titan.State.IsCombo then break end; task.wait() end; task.wait(Utils.HumanDelay(Titan.Config.ActionDelay)) else task.wait(Utils.HumanDelay(Titan.Config.BaseDelay)) end
            end
        end
        Titan.State.IsCombo = false; Utils.Tween(btnRef, {BackgroundTransparency=0.3}, 0.2); Utils.Tween(stroke, {Thickness=1.5, Color=Color3.fromRGB(255,80,80)}, 0.2)
    end)
end

