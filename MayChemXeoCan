local function GetPlayerInfo(plr)
    local lvl, race = "?", "?"
    if plr:FindFirstChild("Data") then
        local lObj = plr.Data:FindFirstChild("Level")
        if lObj then lvl = tostring(lObj.Value) end
        local rObj = plr.Data:FindFirstChild("Race")
        if rObj then race = tostring(rObj.Value) end
    end
    
    local hp, mhp = 0, 0
    local weap = "None"
    local ken = "OFF"
    
    if plr.Character then
        local hum = plr.Character:FindFirstChild("Humanoid")
        if hum then hp = math.floor(hum.Health); mhp = math.floor(hum.MaxHealth) end
        
        local tool = plr.Character:FindFirstChildOfClass("Tool")
        if tool then weap = tool.Name end
        
        local dodge = plr.Character:FindFirstChild("Dodge") or plr.Character:FindFirstChild("Ken")
        if dodge and dodge.Value > 0 then ken = "ON" end
    end
    
    return lvl, race, hp, mhp, weap, ken
end

RunService.Heartbeat:Connect(function()
    if LP.Character then
        local hum = LP.Character:FindFirstChild("Humanoid")
        if hum then
            if hum.MoveDirection.Magnitude > 0 then
                local isSkill = false
                for _, v in ipairs(LP.Character:GetDescendants()) do
                    if v:IsA("BoolValue") and v.Value == true and (string.find(string.lower(v.Name), "usingskill") or string.find(string.lower(v.Name), "busy")) then
                        isSkill = true; break
                    end
                end
                if not isSkill then
                    local tgtSpd = tonumber(Config.WalkSpeed) or 35
                    if hum.WalkSpeed < tgtSpd then hum.WalkSpeed = tgtSpd end
                end
            end
        end
        
        ClearStun(LP.Character)
        
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = plr.Character.HumanoidRootPart
                
                if Config.Hitbox then
                    local hs = tonumber(Config.HitboxSize) or 15
                    hrp.Size = Vector3.new(hs, hs, hs)
                    hrp.Transparency = 0.8
                    hrp.CanCollide = false
                    hrp.Massless = true
                end
                
                local espId = "ESP_" .. plr.Name
                local espGui = hrp:FindFirstChild(espId)
                
                if Config.ESP then
                    if not espGui then
                        espGui = Instance.new("BillboardGui")
                        espGui.Name = espId
                        espGui.Size = UDim2.new(0, 200, 0, 80)
                        espGui.StudsOffset = Vector3.new(0, 3, 0)
                        espGui.AlwaysOnTop = true
                        
                        local txt = Instance.new("TextLabel")
                        txt.Size = UDim2.new(1, 0, 1, 0)
                        txt.BackgroundTransparency = 1
                        txt.TextColor3 = Color3.fromRGB(255, 255, 255)
                        txt.Font = Enum.Font.GothamBold
                        txt.TextSize = 10
                        txt.TextStrokeTransparency = 0
                        txt.Parent = espGui
                        
                        espGui.Parent = hrp
                    end
                    
                    local lvl, race, hp, mhp, weap, ken = GetPlayerInfo(plr)
                    local txtNode = espGui:FindFirstChildOfClass("TextLabel")
                    if txtNode then
                        txtNode.Text = string.format("[Lv. %s] %s\nHP: %d/%d\nRace: %s | Ken: %s\nW: %s", lvl, plr.Name, hp, mhp, race, ken, weap)
                        if hp / mhp < 0.3 then txtNode.TextColor3 = Color3.fromRGB(255, 50, 50) else txtNode.TextColor3 = Color3.fromRGB(255, 255, 255) end
                    end
                else
                    if espGui then espGui:Destroy() end
                end
            end
        end
    end
end)
