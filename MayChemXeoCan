end)

task.spawn(function()
    while task.wait(0.5) do
        ManageESP()
    end
end)

task.spawn(function()
    while true do
        if getgenv().AutoEggUltra and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
            local remainingPoints = {}
            for _, p in ipairs(TweenPoints) do
                table.insert(remainingPoints, p)
            end
            
            while #remainingPoints > 0 and getgenv().AutoEggUltra do
                local hrp = LP.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then break end
                
                local targetPos, index = GetClosestPoint(hrp.Position, remainingPoints)
                if targetPos then
                    table.remove(remainingPoints, index)
                    BypassTween(targetPos + Vector3.new(0, 40, 0))
                    
                    local t = 0
                    while t < 5 and getgenv().AutoEggUltra do
                        AbsoluteGoldenSnipe()
                        task.wait(1)
                        t = t + 1
                    end
                end
            end
            
            if getgenv().AutoEggUltra then
                HitAndRunShip()
            end
        end
        task.wait(1)
    end
end)
