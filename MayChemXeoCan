local function GetFragment()
    local data = LP:FindFirstChild("Data")
    if data then
        local frag = data:FindFirstChild("Fragments") or data:FindFirstChild("Fragment")
        if frag and (frag:IsA("NumberValue") or frag:IsA("IntValue")) then return frag.Value end
    end
    return 0
end

