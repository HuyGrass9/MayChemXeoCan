local function CreateAdvancedSlider(parent, yPos, text, min, max, configKey, isInt)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.9, 0, 0, 15)
    lbl.Position = UDim2.new(0.05, 0, 0, yPos)
    lbl.BackgroundTransparency = 1
    lbl.Text = text .. ": " .. tostring(Config[configKey])
    lbl.TextColor3 = Color3.fromRGB(220, 220, 220)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = parent

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0.9, 0, 0, 12)
    bg.Position = UDim2.new(0.05, 0, 0, yPos + 18)
    bg.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
    bg.Parent = parent

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((Config[configKey] - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 20, 20)
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    fill.Parent = bg

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = bg

    local dragging = false
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            if dragging then dragging = false; SaveConfig() end
        end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging then
            local mousePos = UserInputService:GetMouseLocation().X
            local relPos = mousePos - bg.AbsolutePosition.X
            local pct = math.clamp(relPos / bg.AbsoluteSize.X, 0, 1)
            local val = min + (max - min) * pct
            if isInt then val = math.floor(val) else val = math.floor(val * 1000) / 1000 end
            fill.Size = UDim2.new(pct, 0, 1, 0)
            lbl.Text = text .. ": " .. tostring(val)
            Config[configKey] = val
            
            if configKey == "BtnSize" then
                ExecBtnC.Size = UDim2.new(0, val, 0, val)
                ExecBtnC.TextSize = math.clamp(val * 0.4, 15, 45)
                ExecBtnC2.Size = UDim2.new(0, val, 0, val)
                ExecBtnC2.TextSize = math.clamp(val * 0.4, 15, 45)
            end
        end
    end)
end

