local function MayChemXeoCan_IsHolding(char)
    if not char then return false end
    local tags = {"Charging", "Holding", "UsingSkill", "Stance", "Active", "Channeling", "Power", "Action"}
    for _, tag in ipairs(tags) do if char:FindFirstChild(tag) then return true end end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then for _, tag in ipairs(tags) do if tool:FindFirstChild(tag) then return true end end end
    return false
end

local function GetCurrentWeaponType()
    if not LP.Character then return nil end
    local tool = LP.Character:FindFirstChildOfClass("Tool")
    if tool and tool:FindFirstChild("ToolTip") then
        local tt = string.lower(tool.ToolTip.Value)
        if string.find(tt, "melee") then return "1" end
        if string.find(tt, "fruit") then return "2" end
        if string.find(tt, "sword") then return "3" end
        if string.find(tt, "gun") then return "4" end
    end
    return nil
end

local function ExecuteCombo(comboString, strokeRef, colorOff)
    strokeRef.Color = Color3.fromRGB(0, 255, 100)
    
    task.spawn(function()
        local str = string.upper(comboString)
        local cDelay = tonumber(Config.ComboDelay) or 0.05
        
        for i = 1, #str do
            local char = string.sub(str, i, i)
            local key = nil
            local isWeapon = false
            
            if char == "1" or char == "2" or char == "3" or char == "4" then
                if GetCurrentWeaponType() ~= char then
                    if char == "1" then key = Enum.KeyCode.One
                    elseif char == "2" then key = Enum.KeyCode.Two
                    elseif char == "3" then key = Enum.KeyCode.Three
                    elseif char == "4" then key = Enum.KeyCode.Four
                    end
                    isWeapon = true
                end
            else
                if char == "Z" then key = Enum.KeyCode.Z
                elseif char == "X" then key = Enum.KeyCode.X
                elseif char == "C" then key = Enum.KeyCode.C
                elseif char == "V" then key = Enum.KeyCode.V
                elseif char == "F" then key = Enum.KeyCode.F
                end
            end
            
            if key then
                VIM:SendKeyEvent(true, key, false, game)
                task.wait(0.02)
                VIM:SendKeyEvent(false, key, false, game)
                
                if isWeapon then
                    task.wait(0.2)
                else
                    task.wait(cDelay)
                    local holdTimeout = tick()
                    while MayChemXeoCan_IsHolding(LP.Character) and (tick() - holdTimeout) < 2.5 do
                        RunService.Heartbeat:Wait()
                    end
                end
            end
        end
        strokeRef.Color = colorOff
    end)
end

