local function CreateSlider(yPos, text, min, max, configKey, isInt)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.9, 0, 0, 40)
    frame.Position = UDim2.new(0.05, 0, 0, yPos)
    frame.BackgroundTransparency = 1
    frame.Parent = Menu

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 0, 15)
    lbl.BackgroundTransparency = 1
    lbl.Text = text .. ": " .. tostring(Config[configKey])
    lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = frame

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 0, 10)
    bg.Position = UDim2.new(0, 0, 0, 20)
    bg.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
    bg.Parent = frame

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((Config[configKey] - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    fill.Parent = bg

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = bg

    local dragging = false
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if dragging then dragging = false; SaveConfig() end
        end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging then
            local mousePos = UserInputService:GetMouseLocation().X
            local relPos = mousePos - bg.AbsolutePosition.X
            local pct = math.clamp(relPos / bg.AbsoluteSize.X, 0, 1)
            local val = min + (max - min) * pct
            if isInt then val = math.floor(val) else val = math.floor(val * 100) / 100 end
            fill.Size = UDim2.new(pct, 0, 1, 0)
            lbl.Text = text .. ": " .. tostring(val)
            Config[configKey] = val
            
            if configKey == "BtnSize" then
                ExecBtn.Size = UDim2.new(0, val, 0, val)
                ExecBtn.TextSize = math.clamp(val * 0.4, 10, 40)
            end
        end
    end)
end

