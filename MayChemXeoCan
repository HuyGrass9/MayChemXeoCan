task.spawn(function()
    while true do
        if getgenv().MayChemXeoCan_Auto and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
            local remainingPoints = {}
            for _, p in ipairs(TweenPoints) do
                table.insert(remainingPoints, p)
            end
            
            while #remainingPoints > 0 and getgenv().MayChemXeoCan_Auto do
                local hrp = LP.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then break end
                
                local targetPos, index = GetClosestPoint(hrp.Position, remainingPoints)
                if targetPos then
                    table.remove(remainingPoints, index)
                    BypassTween(targetPos + Vector3.new(0, 45, 0))
                    
                    local timer = 0
                    while timer < 4 and getgenv().MayChemXeoCan_Auto do
                        SnipeGoldenForce()
                        task.wait(0.5)
                        timer = timer + 0.5
                    end
                end
            end
            
            if getgenv().MayChemXeoCan_Auto then
                HitAndRunShip()
            end
        end
        task.wait(1)
    end
end)
