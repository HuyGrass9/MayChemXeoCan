RunService.Heartbeat:Connect(function()
    pcall(function()
        local now = tick()
        local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not myR then return end
        
        Titan.State.Target = TargetEngine.GetValidEnemy()
        if Titan.Config.AutoAim and Titan.State.Target and Titan.State.IsCombo then TargetEngine.ApplyPrediction(Titan.State.Target) end
        
        if Titan.Config.AntiStun then
            for _,v in ipairs(LP.Character:GetChildren()) do
                if v:IsA("BoolValue") and v.Value==true and (string.find(string.lower(v.Name),"stun") or string.find(string.lower(v.Name),"cant") or string.find(string.lower(v.Name),"nodash")) then v.Value=false end
            end
        end
        
        local isMv = LP.Character:FindFirstChild("Humanoid") and LP.Character.Humanoid.MoveDirection.Magnitude > 0
        if Titan.Config.FakeLag and isMv and not Titan.State.IsCombo then
            Titan.State.LagTick = Titan.State.LagTick + 1
            if Titan.State.LagTick >= Titan.Config.FakeLagTick then
                Titan.State.GhostCF = myR.CFrame
                myR.CFrame = Titan.State.GhostCF * CFrame.new(math.random(-8,8), math.random(0,2), math.random(-8,8))
                Titan.State.LagTick = 0
            end
        else Titan.State.LagTick = 0 end
        
        if now - Titan.State.LastTick >= 0.1 then
            Titan.State.LastTick = now
            local cam = workspace.CurrentCamera
            local cF2, cR2 = Vector2.new(cam.CFrame.LookVector.X, cam.CFrame.LookVector.Z).Unit, Vector2.new(cam.CFrame.RightVector.X, cam.CFrame.RightVector.Z).Unit
            
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                    local tR = p.Character.HumanoidRootPart
                    local dist = (tR.Position - myR.Position).Magnitude
                    local isTarg = (p == Titan.State.Target)
                    
                    if Titan.Config.Hitbox then tR.Size = Vector3.new(Titan.Config.HitboxSize, Titan.Config.HitboxSize, Titan.Config.HitboxSize); tR.Transparency = 0.8; tR.CanCollide = false
                    else if tR.Size.X > 5 then tR.Size = Vector3.new(2,2,1); tR.Transparency = 1 end end
                    
                    if Titan.Config.ShowMap then
                        if dist <= Titan.Config.MapRange then
