local function GetPortalButtons()
    local mainGui = LP.PlayerGui:WaitForChild("Main")
    local portalFrame = nil
    for _, v in pairs(mainGui:GetDescendants()) do
        if v:IsA("TextLabel") and v.Visible then
            local txt = string.lower(v.Text)
            if string.find(txt, "cổng dịch chuyển") or string.find(txt, "portal") then
                portalFrame = v.Parent
                break
            end
        end
    end
    local buttons = {}
    if portalFrame then
        for _, v in pairs(portalFrame:GetDescendants()) do
            if (v:IsA("TextButton") or v:IsA("ImageButton")) and v.Visible and v.AbsoluteSize.X > 30 then
                if not string.find(string.lower(v.Name), "close") then
                    table.insert(buttons, v)
                end
            end
        end
        table.sort(buttons, function(a, b)
            if math.abs(a.AbsolutePosition.Y - b.AbsolutePosition.Y) > 15 then
                return a.AbsolutePosition.Y < b.AbsolutePosition.Y
            else
                return a.AbsolutePosition.X < b.AbsolutePosition.X
            end
        end)
    end
    return buttons
end

local function ForceClickButton(btn)
    local clicked = false
    if getconnections then
        pcall(function()
            for _, conn in pairs(getconnections(btn.MouseButton1Click)) do
                conn:Function()
                clicked = true
            end
        end)
    end
    if not clicked then
        local absPos = btn.AbsolutePosition
        local absSize = btn.AbsoluteSize
        VIM:SendMouseButtonEvent(absPos.X + absSize.X/2, absPos.Y + absSize.Y/2 + 36, 0, true, game, 1)
        task.wait(0.1)
        VIM:SendMouseButtonEvent(absPos.X + absSize.X/2, absPos.Y + absSize.Y/2 + 36, 0, false, game, 1)
    end
end

local function SnipeAllEggs()
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Model") or v:IsA("BasePart") then
            local name = string.lower(v.Name)
            if string.find(name, "egg") and not string.find(name, "legg") then
                local targetPart = v:IsA("Model") and (v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Part") or v.PrimaryPart) or v
                local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                if hrp and targetPart and targetPart.Parent then
                    local dist = (hrp.Position - targetPart.Position).Magnitude
                    if dist < 2000 then
                        local tInfo = TweenInfo.new(dist / 400, Enum.EasingStyle.Linear)
                        local tw = TweenService:Create(hrp, tInfo, {CFrame = targetPart.CFrame})
                        tw:Play()
                        local timeout = 0
                        while getgenv().AutoEggUltra and targetPart and targetPart.Parent and timeout < 15 do
                            if (hrp.Position - targetPart.Position).Magnitude < 10 then break end
                            task.wait(0.1)
                            timeout = timeout + 1
                        end
                        if tw then tw:Cancel() end
                    end
                end
            end
        end
    end
end

local function SmoothMoveAway()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local targetCFrame = hrp.CFrame * CFrame.new(0, 40, 50)
        local tInfo = TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
        local tw = TweenService:Create(hrp, tInfo, {CFrame = targetCFrame})
        tw:Play()
        tw.Completed:Wait()
    end
end

