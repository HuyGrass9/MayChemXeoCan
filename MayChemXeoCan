        for _, s in pairs(holdSliders) do s:Destroy() end; table.clear(holdSliders)
        if not txt or txt == "" then return end
        local idx = 0
        for toolType, key in string.gmatch(s_upper(txt), "([1-4])([ZXCVF])") do
