local Utils = {}
function Utils.Tween(obj, props, time) local tw = TweenService:Create(obj, TweenInfo.new(time or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props); tw:Play(); return tw end
function Utils.GetPing() pcall(function() MCXC.State.Ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000 end); return math.clamp(MCXC.State.Ping, 0.02, 0.3) end

local TargetEngine = {}
function TargetEngine.GetValidEnemy()
    local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not myR then return nil end
    local bestTarg, minD = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local dist = (p.Character.HumanoidRootPart.Position - myR.Position).Magnitude
            if dist <= MCXC.Config.LockRange and dist < minD then minD = dist; bestTarg = p end
        end
    end
    return bestTarg
end

function TargetEngine.GetPredPos(target)
    if not target or not target.Character then return nil end
    local tR = target.Character:FindFirstChild("HumanoidRootPart")
    if not tR then return nil end
    local cam = workspace.CurrentCamera
    local dist = (cam.CFrame.Position - tR.Position).Magnitude
    local dropOffset = Vector3.new(0, 1.2 + (dist * 0.005), 0)
    return tR.Position + (tR.Velocity * (Utils.GetPing() + MCXC.Config.Prediction)) - dropOffset
end

local Combat = {}
function Combat.IsBusy(char)
    if not char then return false end
    for _, v in ipairs(char:GetChildren()) do 
        if v:IsA("BoolValue") and v.Value then 
            local n = string.lower(v.Name)
            if string.find(n, "busy") or string.find(n, "using") or string.find(n, "cast") or string.find(n, "charg") then return true end 
        end 
    end
    return false
end

