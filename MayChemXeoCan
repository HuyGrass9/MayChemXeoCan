function Combat.ExecuteCombo(comboStr, btnRef, stroke, baseColor)
    if MCXC.State.IsCombo then return end
    MCXC.State.IsCombo = true; local st = MCXC.Config.StealthMode
    Utils.Tween(btnRef, {BackgroundTransparency = st and 0.8 or 0.1}, 0.1)
    Utils.Tween(stroke, {Thickness = st and 1 or 2.5, Color = Color3.fromRGB(255,255,255)}, 0.1)
    
    task.spawn(function()
        local wasLocked = MCXC.State.IsLocked
        local unl = (MCXC.Config.PremiumKey == "mcxc")
        if unl and MCXC.Config.AutoLockC and not wasLocked then
            local t = TargetEngine.GetValidEnemy()
            if t then MCXC.State.IsLocked = true; MCXC.State.LockedTarget = t end
        end

        if unl and MCXC.State.IsLocked and MCXC.State.LockedTarget then
            local w = tick()
            while tick() - w < 1.0 do
                if MCXC.State.CancelCombo then break end
                local predPos = TargetEngine.GetPredPos(MCXC.State.LockedTarget)
                if not predPos then break end
                local cam = workspace.CurrentCamera
                local dir = (predPos - cam.CFrame.Position).Unit
                cam.CFrame = cam.CFrame:Lerp(CFrame.lookAt(cam.CFrame.Position, predPos), 0.8)
                if cam.CFrame.LookVector:Dot(dir) > 0.995 then break end
                RunService.Heartbeat:Wait()
            end
        end

        task.wait(0.01); local seq = string.upper(comboStr); local first = string.sub(seq,1,1); local cT = LP.Character:FindFirstChildOfClass("Tool")
        if (first=="1" or first=="2" or first=="3" or first=="4") and cT and GetToolType(cT)==first then seq=string.sub(seq,2) end
        for i = 1, #seq do
            if MCXC.State.CancelCombo then break end
            local key = string.sub(seq, i, i)
            if string.match(key, "[1-4]") then
                local tT = LP.Character:FindFirstChildOfClass("Tool"); if not tT or GetToolType(tT)~=key then
                    local kc = Enum.KeyCode.One; if key=="2" then kc=Enum.KeyCode.Two elseif key=="3" then kc=Enum.KeyCode.Three elseif key=="4" then kc=Enum.KeyCode.Four end
                    VIM:SendKeyEvent(true, kc, false, game); task.wait(0.02); VIM:SendKeyEvent(false, kc, false, game); local w=tick(); while tick()-w<0.3 do if MCXC.State.CancelCombo then break end; local tk=LP.Character:FindFirstChildOfClass("Tool"); if tk and GetToolType(tk)==key then break end; task.wait() end; task.wait(0.05)
                end
            elseif string.match(key, "[ZXCVF]") then
                local kc = Enum.KeyCode[key]; VIM:SendKeyEvent(true, kc, false, game); task.wait(0.05); VIM:SendKeyEvent(false, kc, false, game)
                local wR = tick(); local trg = false
                while tick()-wR < 0.4 do if MCXC.State.CancelCombo then break end; if Combat.IsBusy(LP.Character) then trg=true; break end; task.wait() end
                if trg then local wA=tick(); while Combat.IsBusy(LP.Character) and tick()-wA < 3.0 do if MCXC.State.CancelCombo then break end; task.wait() end; task.wait(unl and MCXC.Config.ActionDelay or 0.15) else task.wait(MCXC.Config.BaseDelay) end
            end
        end
        MCXC.State.IsCombo = false; MCXC.State.CancelCombo = false
        if unl and MCXC.Config.AutoLockC and not wasLocked then MCXC.State.IsLocked = false; MCXC.State.LockedTarget = nil end
        Utils.Tween(btnRef, {BackgroundTransparency = st and 1 or 0.3}, 0.2)
        Utils.Tween(stroke, {Thickness = st and 0.5 or 1.5, Color = baseColor}, 0.2)
    end)
end

