        local frm = I_new("ScrollingFrame", Content)
        frm.Size = U2(1, 0, 1, 0); frm.BackgroundTransparency = 1; frm.Visible = false
        frm.ScrollBarThickness = 2; frm.AutomaticCanvasSize = Enum.AutomaticSize.Y
        frm.CanvasSize = U2(0, 0, 0, 0); frm.ScrollingDirection = Enum.ScrollingDirection.Y
        local layout = I_new("UIListLayout", frm); layout.Padding = UD.new(4, 8)

        local tab = { Btn = btn, Frm = frm }; table.insert(self.Tabs, tab)
        btn.MouseButton1Click:Connect(function()
            for _, t in ipairs(self.Tabs) do
                t.Frm.Visible = (t == tab)
                t.Btn.BackgroundColor3 = (t == tab) and Theme.Accent or Theme.ElementBG
                t.Btn.TextColor3 = (t == tab) and Theme.Text or Theme.TextDark
            end
        end)
        if #self.Tabs == 1 then frm.Visible = true; btn.BackgroundColor3 = Theme.Accent; btn.TextColor3 = Theme.Text end

        local TabObj = { Frame = frm, LIdx = 0 }
        function TabObj:CreateToggle(text, key, callback)
