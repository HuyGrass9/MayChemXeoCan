function Utils.MakeDraggable(topbar, object)
    local dragging, dragInput, dragStart, startPos
    topbar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; dragStart = input.Position; startPos = object.Position; input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end) end end)
    topbar.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
    UserInputService.InputChanged:Connect(function(input) if input == dragInput and dragging then local delta = input.Position - dragStart; object.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)
end

function Utils.ApplyLagFixToObj(v)
    pcall(function()
        if v:IsA("BasePart") and not (v.Parent and v.Parent:FindFirstChild("Humanoid")) then v.CastShadow = false; v.Material = Enum.Material.SmoothPlastic
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") then v.Enabled = false; v.Rate = 0
        elseif v:IsA("Explosion") then v.Visible = false; v.BlastPressure = 0; v.BlastRadius = 0
        elseif v:IsA("Texture") or v:IsA("Decal") then v.Transparency = 1 end
    end)
end

local Combat = {}
function Combat.IsStunned(char)
    if not char then return false end
    for _, v in ipairs(char:GetChildren()) do 
        if v:IsA("BoolValue") and v.Value then 
            local n = string.lower(v.Name)
            if string.find(n, "stun") or string.find(n, "cant") then return true end 
        end 
    end
    return false
end

function Combat.IsBusy(char)
    if not char then return false end
    for _, v in ipairs(char:GetChildren()) do 
        if v:IsA("BoolValue") and v.Value then 
            local n = string.lower(v.Name)
            if string.find(n, "busy") or string.find(n, "using") or string.find(n, "cast") or string.find(n, "stun") then return true end 
        end 
    end
    return false
end

function Combat.SW(t)
    local s = tick()
    while tick() - s < t do
        if MCXC.State.CancelCombo or Combat.IsStunned(LP.Character) then
            MCXC.State.CancelCombo = true
            return false
        end
        task.wait()
    end
    return true
end

