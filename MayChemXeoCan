local function SafeGetPlayerInfo(plr)
    local lvl, hp, mhp = "?", 0, 0
    pcall(function()
        if plr:FindFirstChild("Data") and plr.Data:FindFirstChild("Level") then 
            lvl = tostring(plr.Data.Level.Value) 
        end
        if plr.Character then
            local hum = plr.Character:FindFirstChild("Humanoid")
            if hum then hp = math.floor(hum.Health); mhp = math.floor(hum.MaxHealth) end
        end
    end)
    return lvl, hp, mhp
end

RunService.Heartbeat:Connect(function()
    pcall(function()
        if LP.Character then
            if Config.AntiStun then ClearEnemyStun(LP.Character) end
            
            if Config.FakeLag and LP.Character:FindFirstChild("HumanoidRootPart") then
                lagTick = lagTick + 1
                if lagTick >= (tonumber(Config.FakeLagTick) or 15) then
                    local hrp = LP.Character.HumanoidRootPart
                    hrp.Anchored = true
                    task.delay(0.05, function() if hrp then hrp.Anchored = false end end)
                    lagTick = 0
                end
            end
            
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local root = plr.Character.HumanoidRootPart
                    local dist = (root.Position - LP.Character.HumanoidRootPart.Position).Magnitude
                    local maxDist = tonumber(Config.RenderDistance) or 1500
                    
                    if Config.Hitbox and not getgenv().MacroHidden then
                        local hs = tonumber(Config.HitboxSize) or 15
                        root.Size = Vector3.new(hs, hs, hs)
                        root.Transparency = 0.8
                        root.CanCollide = false
                    end
                    
                    local espId = "ESP_" .. plr.Name
                    local espGui = root:FindFirstChild(espId)
                    
                    if Config.ESP and dist <= maxDist and not getgenv().MacroHidden then
                        if not espGui then
                            espGui = Instance.new("BillboardGui")
                            espGui.Name = espId
                            espGui.Size = UDim2.new(0, 200, 0, 50)
                            espGui.StudsOffset = Vector3.new(0, 3, 0)
                            espGui.AlwaysOnTop = true
                            local txt = Instance.new("TextLabel")
                            txt.Name = "TextNode"
                            txt.Size = UDim2.new(1, 0, 1, 0)
                            txt.BackgroundTransparency = 1
                            txt.Font = Enum.Font.GothamBold
                            txt.TextSize = 11
                            txt.TextStrokeTransparency = 0.5
                            txt.Parent = espGui
                            espGui.Parent = root
                        end
                        
                        local lvl, hp, mhp = SafeGetPlayerInfo(plr)
                        local weap = "None"
                        local pTool = plr.Character:FindFirstChildOfClass("Tool")
                        if pTool then weap = pTool.Name end
                        
                        local txtNode = espGui:FindFirstChild("TextNode")
                        if txtNode then
                            txtNode.Text = string.format("[Lv.%s] %s\nHP: %d/%d | W: %s\nDist: %dm", lvl, plr.Name, hp, mhp, string.sub(weap, 1, 15), math.floor(dist))
                            txtNode.TextColor3 = (mhp > 0 and hp / mhp < 0.4) and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(0, 255, 200)
                        end
                    else
                        if espGui then espGui:Destroy() end
                    end
                    
                    local lineId = "TracerLine_" .. plr.Name
                    local line = root:FindFirstChild(lineId)
                    
                    if Config.ViewTracer and dist <= maxDist and not getgenv().MacroHidden then
                        if not line then
                            line = Instance.new("LineHandleAdornment")
                            line.Name = lineId
                            line.Adornee = root
                            line.Thickness = 5
                            line.Length = 50
                            line.ZIndex = 5
                            line.Transparency = 0.2
                            line.AlwaysOnTop = true
                            line.Parent = root
                        end
                        line.Color3 = Color3.fromRGB(Config.TracerR, Config.TracerG, Config.TracerB)
                    else
                        if line then line:Destroy() end
                    end
                end
            end
        end
    end)
end)
