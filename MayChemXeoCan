local function GetToolType(tool)
    if not tool then return "0" end
    local n = string.lower(tool.Name)
    local tt = tool:FindFirstChild("ToolTip")
    local v = tt and tostring(tt.Value) or ""
    local vl = string.lower(v)
    
    if string.find(vl, "melee") or string.find(v, "Cận") or string.find(v, "cận") or string.find(v, "Võ") or string.find(v, "võ") or string.find(n, "human") or string.find(n, "art") or string.find(n, "claw") or string.find(n, "step") or (string.find(n, "dragon") and string.find(n, "talon")) then return "1" end
    if string.find(vl, "fruit") or string.find(v, "Trái") or string.find(v, "trái") or string.find(v, "Quỷ") or string.find(v, "quỷ") or (string.find(n, "dragon") and not string.find(n, "talon") and not string.find(n, "trident")) or string.find(n, "kitsune") or string.find(n, "dough") or string.find(n, "leopard") or string.find(n, "buddha") or string.find(n, "portal") or string.find(n, "rumble") then return "2" end
    if string.find(vl, "sword") or string.find(v, "Kiếm") or string.find(v, "kiếm") or string.find(v, "Đao") or string.find(v, "đao") or string.find(n, "katana") or string.find(n, "blade") or string.find(n, "sword") or string.find(n, "tushita") or string.find(n, "yama") or string.find(n, "saber") or string.find(n, "anchor") or string.find(n, "dark") or string.find(n, "cdk") or string.find(n, "trident") then return "3" end
    if string.find(vl, "gun") or string.find(v, "Súng") or string.find(v, "súng") or string.find(v, "Pháo") or string.find(v, "pháo") or string.find(n, "rifle") or string.find(n, "gun") or string.find(n, "soul") or string.find(n, "kabucha") or string.find(n, "serpent") or string.find(n, "guitar") then return "4" end
    return "0"
end

local function IsSkillBusy(char)
    if not char then return false end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("BoolValue") and v.Value == true then
            local n = string.lower(v.Name)
            if string.find(n, "busy") or string.find(n, "usingskill") or string.find(n, "charging") or string.find(n, "holding") or string.find(n, "power") or string.find(n, "action") or string.find(n, "attack") or string.find(n, "cast") then
                return true
            end
        end
    end
    return false
end

local function ClearEnemyStun(char)
    if not char then return end
    local stuns = {"stun", "cant", "nodash", "nojump"} 
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("BoolValue") and v.Value == true then
            local n = string.lower(v.Name)
            for _, tag in ipairs(stuns) do
                if string.find(n, tag) then v.Value = false end
            end
        end
    end
end

local function SetBtnActiveState(btn, stroke, color, isActive)
    if isActive then
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(255, 255, 255), Thickness = 3}):Play()
    else
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.1}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = color, Thickness = 2}):Play()
    end
end

local function ExecuteForceCombo(comboStr, btnRef, stroke, baseColor)
    SetBtnActiveState(btnRef, stroke, baseColor, true)
    
    if Config.AutoHideC and btnRef.Visible then
        btnRef.Visible = false
        task.delay(Config.HideTimer, function()
            if not getgenv().MacroHidden and ((btnRef == ExecBtnC and Config.ShowC) or (btnRef == ExecBtnC2 and Config.ShowC2)) then
                btnRef.Visible = true
            end
        end)
    end
    
    task.spawn(function()
        task.wait(0.01)
        local s = string.upper(comboStr)
        
        local firstChar = string.sub(s, 1, 1)
        if firstChar == "1" or firstChar == "2" or firstChar == "3" or firstChar == "4" then
            local curTool = LP.Character:FindFirstChildOfClass("Tool")
            if curTool and GetToolType(curTool) == firstChar then
                s = string.sub(s, 2)
            end
        end
        
        for i = 1, #s do
            if getgenv().CancelCombo then break end
            
            local char = string.sub(s, i, i)
            if char == "1" or char == "2" or char == "3" or char == "4" then
                local curTool = LP.Character:FindFirstChildOfClass("Tool")
                if not curTool or GetToolType(curTool) ~= char then
                    local kc
                    if char == "1" then kc = Enum.KeyCode.One
                    elseif char == "2" then kc = Enum.KeyCode.Two
                    elseif char == "3" then kc = Enum.KeyCode.Three
                    elseif char == "4" then kc = Enum.KeyCode.Four
                    end
                    
                    if kc then
                        VIM:SendKeyEvent(true, kc, false, game)
                        task.wait(0.02)
                        VIM:SendKeyEvent(false, kc, false, game)
                        
                        local w = tick()
                        while tick() - w < 0.4 do
                            if getgenv().CancelCombo then break end
                            local t = LP.Character:FindFirstChildOfClass("Tool")
                            if t and GetToolType(t) == char then break end
                            RunService.Heartbeat:Wait()
                        end
                        task.wait(0.05)
                    end
                end
            elseif char == "Z" or char == "X" or char == "C" or char == "V" or char == "F" then
                local kc = Enum.KeyCode[char]
                VIM:SendKeyEvent(true, kc, false, game)
                task.wait(0.05)
                VIM:SendKeyEvent(false, kc, false, game)
                
                local waitReg = tick()
                local triggered = false
                while tick() - waitReg < 0.4 do
                    if getgenv().CancelCombo then break end
                    if IsSkillBusy(LP.Character) then triggered = true; break end
                    RunService.Heartbeat:Wait()
                end
                
                if triggered then
                    local waitAnim = tick()
                    while IsSkillBusy(LP.Character) and tick() - waitAnim < 3.0 do
                        if getgenv().CancelCombo then break end
                        RunService.Heartbeat:Wait()
                    end
                    task.wait(tonumber(Config.ActionDelay) or 0.1)
                else
                    task.wait(tonumber(Config.ComboDelay) or 0.05)
                end
            end
        end
        
        SetBtnActiveState(btnRef, stroke, baseColor, false)
        if btnRef == ExecBtnC2 then getgenv().lockC2 = false else getgenv().lockC = false end
        getgenv().CancelCombo = false
    end)
end

