        if MCXC.State.CurrentCombo == comboId then if MCXC.Config.CancelOnTap then MCXC.State.Status = "IDLE"; Utils.Tween(btnRef, {BackgroundTransparency=0.1}, 0.05); t_delay(0.1, function() Utils.Tween(btnRef, {BackgroundTransparency=MCXC.Config.UITrans}, 0.1) end) end
