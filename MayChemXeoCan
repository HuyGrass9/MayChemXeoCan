local function CreateSlider(parent, yPos, text, min, max, configKey, isInt, btnRef)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 40)
    frame.Position = UDim2.new(0, 0, 0, yPos)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.9, 0, 0, 20)
    lbl.Position = UDim2.new(0.05, 0, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = text .. ": " .. tostring(Config[configKey])
    lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    lbl.Font = Enum.Font.GothamMedium
    lbl.TextSize = 11
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = frame

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0.9, 0, 0, 6)
    bg.Position = UDim2.new(0.05, 0, 0, 25)
    bg.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
    bg.Parent = frame

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((Config[configKey] - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    fill.Parent = bg

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = bg

    local dragging = false
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            if not getgenv().MCXC_ActiveSlider then getgenv().MCXC_ActiveSlider = configKey; dragging = true end
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            if dragging and getgenv().MCXC_ActiveSlider == configKey then dragging = false; getgenv().MCXC_ActiveSlider = nil; SaveConfig() end
        end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging and getgenv().MCXC_ActiveSlider == configKey then
            local mousePos = UserInputService:GetMouseLocation().X
            local relPos = mousePos - bg.AbsolutePosition.X
            local pct = math.clamp(relPos / bg.AbsoluteSize.X, 0, 1)
            local val = min + (max - min) * pct
            if isInt then val = math.floor(val) else val = math.floor(val * 100) / 100 end
            fill.Size = UDim2.new(pct, 0, 1, 0)
            lbl.Text = text .. ": " .. tostring(val)
            Config[configKey] = val
            
            if btnRef then
                btnRef.Size = UDim2.new(0, val, 0, val)
                btnRef.TextSize = math.clamp(val * 0.4, 15, 45)
            end
        end
    end)
    return frame
end

local function CreateToggle(parent, x, y, text, configKey, cb)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.42, 0, 0, 35)
    btn.Position = UDim2.new(x, 0, 0, y)
    btn.BackgroundColor3 = Config[configKey] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(20, 20, 22)
    btn.Text = text
    btn.TextColor3 = Config[configKey] and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(200, 200, 200)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 10
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", btn).Color = Color3.fromRGB(40, 40, 45)
    btn.Parent = parent
    
    btn.MouseButton1Click:Connect(function()
        Config[configKey] = not Config[configKey]
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Config[configKey] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(20, 20, 22)}):Play()
        TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = Config[configKey] and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(200, 200, 200)}):Play()
        SaveConfig()
        if cb then cb(Config[configKey]) end
    end)
end

