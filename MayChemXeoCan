LP.Chatted:Connect(function(m) if s_lower(m) == "mcxc" then Gui.Enabled = true end end)
workspace.DescendantAdded:Connect(function(v) if MCXC.State.LagFixed then table.insert(MCXC.Cache.LagQueue, v) end end)

RS.Heartbeat:Connect(function() 
    if t_tick() - MCXC.State.LastTick > 60 then MCXC.State.LastTick = t_tick(); collectgarbage("step") end
    if #MCXC.Cache.LagQueue > 0 then local batch = 15; while #MCXC.Cache.LagQueue > 0 and batch > 0 do local v = table.remove(MCXC.Cache.LagQueue); MCXC.Utils.ApplySkeletonFix(v); batch = batch - 1 end end
    table.clear(MCXC.State.PlrData); local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not myR then return end; local minD, targ = m_huge, nil
    for _, p in pairs(MCXC.State.ActivePlayers) do 
        if p.Character then local tR, hum = p.Character:FindFirstChild("HumanoidRootPart"), p.Character:FindFirstChild("Humanoid")
            if tR and hum and hum.Health > 0 then local dSq = MCXC.Utils.DistSq(tR.Position, myR.Position); local isAlly = (p.Team == LP.Team and LP.Team ~= nil)
                if not isAlly and dSq < minD then minD, targ = dSq, p end
                local lvl = p:FindFirstChild("Data") and p.Data:FindFirstChild("Level") and tostring(p.Data.Level.Value) or "?"; MCXC.State.PlrData[p.Name] = {tR = tR, dSq = dSq, hp = m_floor(hum.Health), mhp = m_floor(hum.MaxHealth), lvl = lvl, isAlly = isAlly} 
            end 
        end 
    end; MCXC.State.CurrentTarget = targ 
end)

local fF, lFT = 0, t_tick()
RS.RenderStepped:Connect(function() 
    local n = t_tick(); fF = fF + 1; if n - lFT >= 1 then local fps = m_floor(fF / (n - lFT)); fF, lFT = 0, n; MCXC.State.Ping = St.Network.ServerStatsItem["Data Ping"]:GetValue()/1000
        if MCXC.Cache.FPSLbl and MCXC.Cache.PingLbl then MCXC.Cache.FPSLbl.Text, MCXC.Cache.PingLbl.Text = "FPS: "..fps, "PING: "..m_floor(MCXC.State.Ping*1000).."ms" end 
    end
    local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart"); if not myR then return end; local targ = MCXC.State.CurrentTarget
    if MCXC.Config.ViewTracer and targ and MCXC.State.PlrData[targ.Name] then local d = MCXC.State.PlrData[targ.Name]
        if d.dSq <= (MCXC.Config.TracerRange^2) then MCXC.Visuals.UpdateTracer(d.tR, myR, Theme.Target) else MCXC.Visuals.ClearTracer() end
    else MCXC.Visuals.ClearTracer() end
    for _, p in pairs(MCXC.State.ActivePlayers) do local d = MCXC.State.PlrData[p.Name]; if d then MCXC.Visuals.UpdateESP(p, d.tR, d.dSq, (p == targ), d.isAlly, d.hp, d.mhp, d.lvl) 
        else if MCXC.Cache.ESP[p.Name] then MCXC.Cache.ESP[p.Name].Enabled = false end end 
    end 
end)
